nrmk1cqnnk57vvn2cqgjynbx-reenable_DT_HASH.patch"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("BASH_SHELL","/bin/sh"),("LOCALEDEF_FLAGS","--little-endian"),("NIX_NO_SELF_RPATH","1"),("__structuredAttrs",""),("buildInputs","/nix/store/sylp0r40g81gkq95lzqjjbbwchx00vbm-linux-headers-6.18.7"),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("cmakeFlags",""),("configureFlags","-C --enable-add-ons --sysconfdir=/etc --enable-stack-protector=strong --enable-bind-now --without-headers --disable-profile --enable-fortify-source --enable-static-pie"),("depsBuildBuild","/nix/store/dx6cb2nbh1kh0d6f1mv27l7q4lk1jgbd-gcc-wrapper-15.2.0"),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("doCheck",""),("doInstallCheck",""),("enableParallelBuilding","1"),("enableParallelChecking","1"),("enableParallelInstalling","1"),("extraNativeBuildInputs","/nix/store/p1f881g5hgakqag26rlbzbxhzw9gmjnx-glibc-2.42-61"),("installFlags","sysconfdir=$(out)/etc"),("installPhase","mkdir -p \"$out/lib/locale\" \"$out/share/i18n\"\ncp -v \"$TMPDIR/$NIX_STORE/\"*\"/lib/locale/locale-archive\" \"$out/lib/locale\"\ncp -v ../localedata/SUPPORTED \"$out/share/i18n/SUPPORTED\"\n"),("is64bit",""),("linuxHeaders",""),("makeFlags","OBJCOPY=objcopy BUILD_LDFLAGS=-Wl,-rpath,/nix/store/p1f881g5hgakqag26rlbzbxhzw9gmjnx-glibc-2.42-61/lib OBJDUMP=/nix/store/kyan9443h0f7l22zmdk3gj2lm4pwyr5a-binutils-2.46/bin/objdump localedata/install-locales localedir=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9/lib/locale"),("mesonFlags",""),("name","glibc-locales-2.42-61"),("nativeBuildInputs","/nix/store/i81gcs7mqj62xhqn3zlg9655h3vbm85z-bison-3.8.2 /nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0 /nix/store/vkxxaib24h2dl7srfmmcmw5ncm1kka3z-python3-minimal-3.13.13 /nix/store/8b79ylscygvnq4sh92d80zipr4am7pic-glibc-2.42-61-dev"),("out","/nix/store/1wi2l2gk7j16da09255xq52byc7x72pa-glibc-locales-2.42-61"),("outputs","out"),("patches","/nix/store/rdqv4vr2jrjclnk2hdcrj97zqv5ny9z6-2.42-master.patch /nix/store/nc5hqqizlj7042vvhvx121kzf4nwh35p-nix-locale-archive.patch /nix/store/b1w7zbvm39ff1i52iyjggyvw2rdxz104-dont-use-system-ld-so-cache.patch /nix/store/mnglr8rr7nl444h7p50ysyq8qd0fm1lm-dont-use-system-ld-so-preload.patch /nix/store/llr530f1l6c470xkl2w80k2kkfqddmpm-fix_path_attribute_in_getconf.patch /nix/store/7kw224hdyxd7115lrqh9a4dv2x8msq2s-fix-x64-abi.patch /nix/store/001gp43bjqzx60cg345n2slzg7131za8-nix-nss-open-files.patch /nix/store/0mb1pqwqkz9sk1fwgn897zlwzhhgfpbf-0001-Revert-Remove-all-usage-of-BASH-or-BASH-in-installed.patch /nix/store/sj0qllprnrmk1cqnnk57vvn2cqgjynbx-reenable_DT_HASH.patch /nix/store/f1qmmr4f6mi99xr5bvfrqmynjx9j038p-0001-localedata-allow-reproducible-parallel-install-of-lo.patch /nix/store/62qh08ij1zvw5lxj69n98lzv0byda0di-0002-Makeconfig-make-inst_complocaledir-overridable.patch"),("pname","glibc-locales"),("postConfigure","# Hack: get rid of the `-static' flag set by the bootstrap stdenv.\n# This has to be done *after* `configure' because it builds some\n# test binaries.\nexport NIX_CFLAGS_LINK=\nexport NIX_LDFLAGS_BEFORE=\n\nexport NIX_DONT_SET_RPATH=1\nunset CFLAGS\n"),("postInstall","moveToOutput bin/getent $getent\n"),("postPatch","# Needed for glibc to build with the gnumake 3.82\n# http://comments.gmane.org/gmane.linux.lfs.support/31227\nsed -i 's/ot \\$/ot:\\n\\ttouch $@\\n$/' manual/Makefile\n\n# nscd needs libgcc, and we don't want it dynamically linked\n# because we don't want it to depend on bootstrap-tools libs.\necho \"LDFLAGS-nscd += -static-libgcc\" >> nscd/Makefile\n\n# Ensure that `__nss_files_fopen` can still be wrapped by `libredirect`.\nsed -i -e '/libc_hidden_def (__nss_files_fopen)/d' nss/nss_files_fopen.c\nsed -i -e '/libc_hidden_proto (__nss_files_fopen)/d' include/nss_files.h\n\n# Ensure that libidn2 is found.\npatch -p 1 <<EOF\n--- a/inet/idna.c\n+++ b/inet/idna.c\n@@ -25,1 +25,1 @@\n-#define LIBIDN2_SONAME \"libidn2.so.0\"\n+#define LIBIDN2_SONAME \"/nix/store/rlx2m7r37vg356cal0i4hcazlx55ydfb-libidn2-2.3.8/lib/libidn2.so.0\"\nEOF\n"),("preBuild","# Awful hack: `localedef' doesn't allow the path to `locale-archive'\n# to be overriden, but you *can* specify a prefix, i.e. it will use\n# <prefix>/<path-to-glibc>/lib/locale/locale-archive.  So we use\n# $TMPDIR as a prefix, meaning that the locale-archive is placed in\n# $TMPDIR/nix/store/...-glibc-.../lib/locale/locale-archive.\nLOCALEDEF_FLAGS+=\" --prefix=$TMPDIR\"\n\nexport inst_complocaledir=\"$TMPDIR/\"/nix/store/p1f881g5hgakqag26rlbzbxhzw9gmjnx-glibc-2.42-61/lib/locale\nmkdir -p \"$inst_complocaledir\"\n\necho 'C.UTF-8/UTF-8 \\' >> ../localedata/SUPPORTED\n\n# Hack to allow building of the locales (needed since glibc-2.12)\nsubstituteInPlace ../localedata/Makefile \\\n  --replace-fail '$(rtld-prefix) $(common-objpfx)locale/localedef' 'localedef $(LOCALEDEF_FLAGS)'\n# Check that all locales to be built are supported\necho -n 'en_US.UTF-8/UTF-8 \\\n' \\\n  | sort -u > locales-to-build.txt\ncat ../localedata/SUPPORTED | grep ' \\\\' \\\n  | sort -u > locales-supported.txt\ncomm -13 locales-supported.txt locales-to-build.txt \\\n  > locales-unsupported.txt\nif [[ $(wc -c locales-unsupported.txt) != \"0 locales-unsupported.txt\" ]]; then\n  cat locales-supported.txt\n  echo \"Error: unsupported locales detected:\"\n  cat locales-unsupported.txt\n  echo \"You should choose from the list above the error.\"\n  false\nfi\n\necho SUPPORTED-LOCALES='en_US.UTF-8/UTF-8' > ../localedata/SUPPORTED\n"),("preConfigure","export PWD_P=$(type -tP pwd)\nfor i in configure io/ftwtest-sh; do\n    # Can't use substituteInPlace here because replace hasn't been\n    # built yet in the bootstrap.\n    sed -i \"$i\" -e \"s^/bin/pwd^$PWD_P^g\"\ndone\n\nmkdir build\ncd build\n\nconfigureScript=\"`pwd`/../configure\"\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("setupHook","/nix/store/hglg25n2qyblgjvx5028525j5m39z33m-locales-setup-hook.sh"),("src","/nix/store/6zxixmszg0vbhpaa8rxwfr05by9axj68-glibc-2.42.tar.xz"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","2.42-61")])