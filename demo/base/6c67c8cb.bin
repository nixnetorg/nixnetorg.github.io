s\"\nmyhostname=\"nixpkgs\"\ncf_by=\"nixpkgs\"\ncf_time=\"$(date -d \"@$SOURCE_DATE_EPOCH\")\"\nEOF\n\n# Compress::Raw::Zlib should use our zlib package instead of the one\n# included with the distribution\ncat > ./cpan/Compress-Raw-Zlib/config.in <<EOF\nBUILD_ZLIB   = False\nINCLUDE      = /nix/store/wdkjfvpavi712wsgdzbvgkdc6s9bsfcm-zlib-1.3.2-dev/include\nLIB          = /nix/store/9qaxcf6ihcnbxkac7n2621icys84h8ws-zlib-1.3.2/lib\nOLD_ZLIB     = False\nGZIP_OS_CODE = AUTO_DETECT\nUSE_ZLIB_NG  = False\nZLIB_INCLUDE = /nix/store/wdkjfvpavi712wsgdzbvgkdc6s9bsfcm-zlib-1.3.2-dev/include\nZLIB_LIB     = /nix/store/9qaxcf6ihcnbxkac7n2621icys84h8ws-zlib-1.3.2/lib\nEOF\n"),("propagatedBuildInputs","/nix/store/jwws8kb2mfphcmxhlzh03ikz98hlap3d-libxcrypt-4.5.2"),("propagatedNativeBuildInputs",""),("setOutputFlags",""),("setupHook","/nix/store/dm81j9qdcdr4c458pqbc9wvq9ymgzk4m-setup-hook.sh"),("src","/nix/store/mhcbhc42ymmh2laf6yr0m2jimr07y8z0-perl-5.42.0.tar.gz"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","5.42.0")])