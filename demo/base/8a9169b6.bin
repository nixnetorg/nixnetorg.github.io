do\n        if ! [[ \"$NAME\" =~ ^CONFIG_ ]]; then continue; fi\n\n        echo \"parseconfig: removing $NAME\"\n        sed -i /$NAME'\\(=\\| \\)'/d .config\n\n        echo \"parseconfig: setting $NAME=$OPTION\"\n        echo \"$NAME=$OPTION\" >> .config\n    done\n}\n\n\ncat << EOF | parseconfig\n\nCONFIG_PREFIX \"$out\"\nCONFIG_INSTALL_NO_USR y\n\nCONFIG_LFS y\n\n# More features for modprobe.\nCONFIG_FEATURE_MODPROBE_BLACKLIST y\nCONFIG_FEATURE_MODUTILS_ALIAS y\nCONFIG_FEATURE_MODUTILS_SYMBOLS y\nCONFIG_MODPROBE_SMALL n\n\n\n\n\n\n\n# Use the external mount.cifs program.\nCONFIG_FEATURE_MOUNT_CIFS n\nCONFIG_FEATURE_MOUNT_HELPERS y\n\n# Set paths for console fonts.\nCONFIG_DEFAULT_SETFONT_DIR \"/etc/kbd\"\n\n# Bump from 4KB, much faster I/O\nCONFIG_FEATURE_COPYBUF_KB 64\n\n# Doesn't build with current kernel headers.\n# https://bugs.busybox.net/show_bug.cgi?id=15934\nCONFIG_TC n\n\n# Set the path for the udhcpc script\nCONFIG_UDHCPC_DEFAULT_SCRIPT \"$out/default.script\"\n\n\nCONFIG_CROSS_COMPILER_PREFIX \"\"\n\nEOF\n\nmake oldconfig\n\nrunHook postConfigure\n"),("debug","/nix/store/s66mq4rync2d0q0cxmk7g9ahf9mddh09-busybox-1.37.0-debug"),("depsBuildBuild","/nix/store/dx6cb2nbh1kh0d6f1mv27l7q4lk1jgbd-gcc-wrapper-15.2.0"),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("doCheck",""),("doInstallCheck",""),("enableParallelBuilding","1"),("enableParallelChecking","1"),("enableParallelInstalling","1"),("hardeningDisable","format"),("makeFlags","SKIP_STRIP=y"),("mesonFlags",""),("name","busybox-1.37.0"),("nativeBuildInputs","/nix/store/r989dk196nl9frhnfsa1lb7knhbyjxw6-separate-debug-info.sh"),("out","/nix/store/fywvgplddvny50z89xi7lc6024p58ngg-busybox-1.37.0"),("outputs","out debug"),("patches","/nix/store/7wpjbl21q85z0vrqdx4c7lxg6n4rgwh7-busybox-in-store.patch /nix/store/ix0srl7w9s21y5bnpp4q8gmg7jwvjynd-fix-aarch64-sha1.pat