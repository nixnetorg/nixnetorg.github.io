Derive([("out","/nix/store/nw3qs7z5bmcx9hqkz47zn71vn7najyka-musl-1.2.6","","")],[("/nix/store/1sv2fd6hbpx9is0al4vy28r1pwg0vjgp-tinycc-musl-unstable-2025-12-03-libs.drv",["out"]),("/nix/store/3lzzxwghw0y2xqga8l3b6snhmw6mb215-bootstrap-coreutils-5.0.drv",["out"]),("/nix/store/59pgig863abfc3p6lmz20vh8gjf2nsv1-musl-1.2.6.tar.gz.drv",["out"]),("/nix/store/9kv90ksk38v7jjcgjhsfqm1a9ngqw0li-gnumake-4.4.1.drv",["out"]),("/nix/store/gplz0f8nzzzfxqf5848d8gw8z4id3dq5-gzip-1.2.4.drv",["out"]),("/nix/store/hp37ysjg2663kmdmvi945qqlrkiw3vmr-gnutar-1.12.drv",["out"]),("/nix/store/kn6lqyzfx5k98l39nzf2kiq2zq8w0adx-gnused-mes-4.0.9.drv",["out"]),("/nix/store/nfqnml0i1gf4ndlnmzrizzl726phcpv8-gnupatch-2.5.9.drv",["out"]),("/nix/store/pz1z6acpb6x0gyrbysy9rs47vhn4qgzf-mescc-tools-extra-1.9.1.drv",["out"]),("/nix/store/swd5ilalrln5hc0vk0d4i3d1566rvnng-bash-2.05b.drv",["out"]),("/nix/store/w9xa4m8cah6aaq8kwpvnr2w5ghnf1xk2-tinycc-musl-unstable-2025-12-03-compiler.drv",["out"]),("/nix/store/zc4i6kv4525v20s2zh7fhxj1gcbcgggq-sigsetjmp.patch.drv",["out"]),("/nix/store/zygspa3c9cxvd4bym18yn6hahpvg48a1-gnugrep-2.4.drv",["out"])],["/nix/store/9hvp9axa7zm732xi5jvg8pckvfk6ixcj-bash-builder.sh"],"i686-linux","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash",["-e","/nix/store/9hvp9axa7zm732xi5jvg8pckvfk6ixcj-bash-builder.sh"],[("PATH","/nix/store/z5jfacjddmipy4kbb147hkd85ipq7mlr-tinycc-musl-unstable-2025-12-03-compiler/bin:/nix/store/f7gyqiddd36xm9wfyj80ap7agacb0zjb-gnumake-4.4.1/bin:/nix/store/rmg3bi9pkk7y7pjcr0z9km5bngpkmbw8-gnupatch-2.5.9/bin:/nix/store/a7h3s2npx00vwlx4r1ynl9xxqjg0c357-gnused-mes-4.0.9/bin:/nix/store/8iw88kcninwzwbk02xms6cr1q7yj3fx7-gnugrep-2.4/bin:/nix/store/xjw5xk5hidsqrg9ans9csfg46rp67dz6-gnutar-1.12/bin:/nix/store/1dwbpwfrydg8ayw0bin93gnkgbdxcgi7-gzip-1.2.4/bin:/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin:/nix/store/pp0yi0xvymmfqv3nwbbh0rfglbs5zqih-bootstrap-coreutils-5.0/bin:/nix/store/wrv08hp23d4r3y7im82mz9wagncycpzi-mescc-tools-extra-1.9.1/bin"),("SHELL","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("buildCommand","# Unpack\ntar xzf /nix/store/1j3vmqzmlbx2j10q0j061fqychxd7q4i-musl-1.2.6.tar.gz\ncd musl-1.2.6\n\n# Patch\npatch -Np0 -i /nix/store/gg3z1dg2p54gc1zxj0m5a40kzgb0biqm-sigsetjmp.patch\n# tcc does not support complex types\nrm -rf src/complex\n# Configure fails without this\nmkdir -p /dev\n# https://github.com/ZilchOS/bootstrap-from-tcc/blob/2e0c68c36b3437386f786d619bc9a16177f2e149/using-nix/2a3-intermediate-musl.nix\nsed -i 's|/bin/sh|/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash|' \\\n  tools/*.sh\nchmod 755 tools/*.sh\n# patch popen/system to search in PATH instead of hardcoding /bin/sh\nsed -i 's|posix_spawn(&pid, \"/bin/sh\",|posix_spawnp(\\&pid, \"sh\",|' \\\n  src/stdio/popen.c src/process/system.c\nsed -i 's|execl(\"/bin/sh\", \"sh\", \"-c\",|execlp(\"sh\", \"-c\",|'\\\n  src/misc/wordexp.c\n\n# @PLT specifier is not supported by tinycc.\n# Calls do go through PLT regardless.\nsed -i 's|@PLT||' src/math/x86_64/expl.s\nsed -i 's|@PLT||' src/signal/x86_64/sigsetjmp.s\n\n# TODO Implement the required asm constraints 'x' and 't' in tinycc.\n# For now, we just remove code using those constraints. musl automatically\n# polyfills with pure C implementations.\nrm src/math/i386/*.c\nrm src/math/x86_64/*.c\n\n# Configure\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --disable-shared \\\n  CC=tcc\n\n# Build\n# NOTE: parallel build (-j) under tcc here is unstable and broke a previous run.\nmake AR=\"tcc -ar\" RANLIB=true CFLAGS=\"-DSYSCALL_NO_TLS\"\n\n# Install\nmake install\ncp /nix/store/6vdc0y7rd2d0l6js2gipxk7pjqr7zmsw-tinycc-musl-unstable-2025-12-03-libs/lib/libtcc1.a $out/lib\n"),("builder","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("name","musl-1.2.6"),("out","/nix/store/nw3qs7z5bmcx9hqkz47zn71vn7najyka-musl-1.2.6"),("passAsFile","buildCommand"),("pname","musl"),("system","i686-linux"),("version","1.2.6")])