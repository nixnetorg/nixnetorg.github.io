/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh","/nix/store/xprdd33cnqprwk19lxi57h907fz7xic2-git-sh-i18n.patch"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__json","{\"NIX_LDFLAGS\":\"-lgcc_s\",\"NIX_MAIN_PROGRAM\":\"git\",\"buildInputs\":[\"/nix/store/cd96rsmv6l16zk1fx8yhzm15k36jns8w-curl-8.20.0-dev\",\"/nix/store/45kp2zmmhrwys6fiyxm9alqh8dsjq7af-openssl-3.6.2-dev\",\"/nix/store/rmjxsdznv8h23lgkmx79qxgs0b8bgim9-zlib-ng-2.3.3-dev\",\"/nix/store/l9qzw3nv3q9z1h7y5vl926rb3r42ydy9-expat-2.8.0-dev\",\"/nix/store/cbl8cichxkvnpw9ba8ns9353l7m4pcq8-glibc-iconv-2.42\",\"/nix/store/0rkrfxij6sc1g27msvk70w7d7gr4yah8-bash-interactive-5.3p9-dev\"],\"builder\":\"/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\",\"cmakeFlags\":[],\"configureFlags\":[\"ac_cv_prog_CURL_CONFIG=/nix/store/cd96rsmv6l16zk1fx8yhzm15k36jns8w-curl-8.20.0-dev/bin/curl-config\"],\"depsBuildBuild\":[],\"depsBuildBuildPropagated\":[],\"depsBuildTarget\":[],\"depsBuildTargetPropagated\":[],\"depsHostHost\":[],\"depsHostHostPropagated\":[],\"depsTargetTarget\":[],\"depsTargetTargetPropagated\":[],\"doCheck\":false,\"doInstallCheck\":true,\"enableParallelBuilding\":true,\"enableParallelChecking\":true,\"enableParallelInstalling\":true,\"env\":{\"NIX_LDFLAGS\":\"-lgcc_s\",\"NIX_MAIN_PROGRAM\":\"git\"},\"installCheckFlags\":[\"DEFAULT_TEST_TARGET=prove\",\"PERL_PATH=/nix/store/vabrsyx4s3sn35x98yz66dakxxajd0xd-perl-5.42.0/bin/perl\"],\"installCheckTarget\":\"test\",\"installFlags\":[\"NO_INSTALL_HARDLINKS=1\"],\"makeFlags\":[\"prefix=${out}\",\"ZLIB_NG=1\",\"SHELL_PATH=/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\",\"NO_PERL=1\",\"NO_PYTHON=1\",\"sysconfdir=/etc\"],\"mesonFlags\":[],\"name\":\"git-minimal-2.54.0\",\"nativeBuildInputs\":[\"/nix/store/cz9fbchwgmnpvbwk1hgh71ig1wlz966j-uname\",\"/nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0\",\"/nix/store/vabrsyx4s3sn35x98yz66dakxxajd0xd-perl-5.42.0\",\"/nix/store/wajh14qai1lyy314blmzk3lkyk230563-make-shell-wrapper-hook\",\"/nix/store/x17mq9srwk8lxv0797r39d4k3zbrzz0n-pkg-config-wrapper-0.29.2\",\"/nix/store/r989dk196nl9frhnfsa1lb7knhbyjxw6-separate-debug-info.sh\"],\"outputChecks\":{\"debug\":{},\"out\":{\"disallowedReferences\":[]}},\"outputs\":[\"out\",\"debug\"],\"patches\":[\"/nix/store/j6vpikcvv4ry0pwalvpz1m65k2wckavl-docbook2texi.patch\",\"/nix/store/xprdd33cnqprwk19lxi57h907fz7xic2-git-sh-i18n.patch\",\"/nix/store/85ax0pclk9prgkp8d7m6n6q1g7v5m58j-git-send-email-honor-PATH.patch\",\"/nix/store/k7c6k6zwjh9fgzm9fazn9l1qm6wnv0cy-t7703-ignore-ls-total.patch\",\"/nix/store/fzzc79ndlidjp84dx1mxr4ir8sgi3msm-expect-gui--askyesno-failure-in-t1517.patch\"],\"pname\":\"git-minimal\",\"postBuild\":\"# Set up the flags array for make in the same way as for the main build\\n# phase from stdenv.\\nlocal flagsArray=(\\n    ${enableParallelBuilding:+-j${NIX_BUILD_CORES}}\\n    SHELL=\\\"$SHELL\\\"\\n)\\nconcatTo flagsArray makeFlags makeFlagsArray buildFlags buildFlagsArray\\nechoCmd 'build flags' \\\"${flagsArray[@]}\\\"\\nmake -C contrib/subtree \\\"${flagsArray[@]}\\\" all \\nunset flagsArray\\n\",\"postInstall\":\"# Set up the flags array for make in the same way as for the main install\\n# phase from stdenv.\\nlocal flagsArray=(\\n    ${enableParallelInstalling:+-j${NIX_BUILD_CORES}}\\n    SHELL=\\\"$SHELL\\\"\\n)\\nconcatTo flagsArray makeFlags makeFlagsArray installFlags installFlagsArray\\nechoCmd 'install flags' \\\"${flagsArray[@]}\\\"\\n\\n# Install git-subtree.\\nmake -C contrib/subtree \\\"${flagsArray[@]}\\\" install \\nrm -rf contrib/subtree\\n\\n# Install contrib stuff.\\nmkdir -p $out/share/git\\ncp -a contrib $out/share/git/\\nmkdir -p $out/share/bash-completion/completions\\nln -s $out/share/git/contrib/completion/git-prompt.sh $out/share/bash-completion/completions/\\n\\n# grep is a runtime dependency, need to patch so that it's found\\nsubstituteInPlace $out/libexec/git-core/git-sh-setup \\\\\\n    --replace ' grep' ' /nix/store/k3883z8hn5hsmmd5x95471h0dsxs0bg9-gnugrep-3.12/bin/grep' \\\\\\n    --replace ' egrep' ' /nix/store/k3883z8hn5hsmmd5x95471h0dsxs0bg9-gnugrep-3.12/bin/egrep'\\n\\n# Fix references to the perl, sed, awk and various coreutil binaries used by\\n# shell scripts that git calls (e.g. filter-branch)\\nSCRIPT=\\\"$(cat <<'EOS'\\n  BEGIN{\\n    @a=(\\n      '/nix/store/k3883z8hn5hsmmd5x95471h0dsxs0bg9-gnugrep-3.12/bin/grep', '/nix/store/grfx2bhxnd8d1dp5kx1sjj4a8k65f0i9-gnused-4.9/bin/sed', '/nix/store/k5zhlfa1qnhwaslkhd9crbmfr1s6hvhi-gawk-5.4.0/bin/awk',\\n      '/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin/cut', '/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin/basename', '/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin/dirname',\\n      '/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin/wc', '/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin/tr'\\n      \\n    );\\n  }\\n  foreach $c (@a) {\\n    $n=(split(\\\"/\\\", $c))[-1];\\n    s|(?<=[^#][^/.-])\\\\b${n}(?=\\\\s)|${c}|g\\n  }\\nEOS\\n)\\\"\\nperl -0777 -i -pe \\\"$SCRIPT\\\" \\\\\\n  $out/libexec/git-core/git-{sh-setup,filter-branch,merge-octopus,mergetool,quiltimport,request-pull,submodule,subtree,web--browse}\\n\\n\\n# Also put git-http-backend into $PATH, so that we can use smart\\n# HTTP(s) transports for pushing\\nln -s $out/libexec/git-core/git-http-backend $out/bin/git-http-backend\\nln -s $out/share/git/contrib/git-jump/git-jump $out/bin/git-jump\\nrm $out/libexec/git-core/git-svn\\nrm $out/libexec/git-core/git-send-email\\nfor prog in bin/gitk libexec/git-core/git-gui; do\\n  rm \\\"$out/$prog\\\"\\ndone\\nunset flagsArray\\n\",\"postPatch\":\"# Fix references to gettext introduced by ./git-sh-i18n.patch\\nsubstituteInPlace git-sh-i18n.sh \\\\\\n    --subst-var-by gettext /nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0\\nsubstituteInPlace contrib/credential/libsecret/Makefile \\\\\\n    --replace-fail 'pkg-config' \\\"$PKG_CONFIG\\\"\\n# ensure we are using the correct shell when executing the test scripts\\npatchShebangs t/*.sh\\n\",\"preBuild\":\"makeFlagsArray+=( perllibdir=$out/$(perl -MConfig -wle 'print substr $Config{installsitelib}, 1 + length $Config{siteprefixexp}') )\\n\",\"preInstall\":\"\",\"preInstallCheck\":\"# Some tests break with high concurrency\\n# https://github.com/NixOS/nixpkgs/pull/403237\\nif ((NIX_BUILD_CORES > 32)); then\\n  NIX_BUILD_CORES=32\\nfi\\n\\ninstallCheckFlagsArray+=(\\n  GIT_PROVE_OPTS=\\\"--jobs $NIX_BUILD_CORES --failures --state=failed,save\\\"\\n  GIT_TEST_INSTALLED=$out/bin\\n  NO_SVN_TESTS=y\\n)\\n\\nfunction disable_test {\\n  local test=$1 pattern=$2\\n  if [ $# -eq 1 ]; then\\n    mv t/{,skip-}$test.sh || true\\n  else\\n    sed -i t/$test.sh \\\\\\n      -e \\\"/^\\\\s*test_expect_.*$pattern/,/^\\\\s*' *\\\\$/{s/^/: #/}\\\"\\n  fi\\n}\\n\\n# Shared permissions are forbidden in sandbox builds:\\nsubstituteInPlace t/test-lib.sh \\\\\\n  --replace \\\"test_set_prereq POSIXPERM\\\" \\\"\\\"\\n# TODO: Investigate while these still fail (without POSIXPERM):\\n# Tested to fail: 2.46.0\\ndisable_test t0001-init 'shared overrides system'\\n# Tested to fail: 2.46.0\\ndisable_test t0001-init 'init honors global core.sharedRepository'\\n# Tested to fail: 2.46.0\\ndisable_test t1301-shared-repo\\n# /build/git-2.44.0/contrib/completion/git-completion.bash: line 452: compgen: command not found\\ndisable_test t9902-completion\\n# Disable sendmail tests\\ndisable_test t9001-send-email\\n# Flaky tests:\\ndisable_test t0027-auto-crlf\\ndisable_test t1451-fsck-buffer\\ndisable_test t5319-multi-pack-index\\ndisable_test t6421-merge-partial-clone\\ndisable_test t7504-commit-msg-hook\\ndisable_test t5515-fetch-merge-logic\\ndisable_test t4104-apply-boundary\\ndisable_test t7002-mv-sparse-checkout\\ndisable_test t4122-apply-symlink-inside\\ndisable_test t7513-interpret-trailers\\ndisable_test t2200-add-update\\n\\n# Fails reproducibly on ZFS on Linux with formD normalization\\ndisable_test t0021-conversion\\ndisable_test t3910-mac-os-precompose\\n\",\"propagatedBuildInputs\":[],\"propagatedNativeBuildInputs\":[],\"separateDebugInfo\":true,\"src\":\"/nix/store/drcyzlalnx264vlmp2js5vp2kkvyn132-git-2.54.0.tar.xz\",\"stdenv\":\"/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux\",\"strictDeps\":false,\"stripDebugList\":[\"lib\",\"libexec\",\"bin\",\"share/git/contrib/credential\"],\"system\":\"i686-linux\",\"version\":\"2.54.0\"}"),("debug","/nix/store/1mf6x3jp2pfxwgfhl7hghq3nh9m66vqz-git-minimal-2.54.0-debug"),("out","/nix/store/rf3waqm18vi8h54if7jmg0fix67bzngp-git-minimal-2.54.0")])