Derive([("out","/nix/store/dazm0w6r8bignl7mcrw76877nyxpxqkb-python-3.14.4","","")],[("/nix/store/16hpxa0j137szhk78p6w4fxw6irykzjd-bootstrap-coreutils-musl-9.10.drv",["out"]),("/nix/store/44s5n7ii44q4f4z1siwavx5wr5bk75a0-xz-5.8.3.drv",["out"]),("/nix/store/4ffpb0qnw94mpb8pc65w31m1gyii6ash-bash-5.3.drv",["out"]),("/nix/store/7hg5sfggn94jqspza2r7csyzyih9ss2y-diffutils-3.8.drv",["out"]),("/nix/store/8kqkwki4v23dns840qq8mw2g0z37fl5g-gawk-5.3.2.drv",["out"]),("/nix/store/a0cz6plamv634sihp4drgx4bpxh63jlh-findutils-4.10.0.drv",["out"]),("/nix/store/akjyplvgd19p7sg4xlaqa028fkq2favz-gcc-15.2.0.drv",["out"]),("/nix/store/b9iqif0kvs9ijbn9d5qwcmzza2idg463-binutils-2.46.0.drv",["out"]),("/nix/store/bdj46h5g4j93w9a3zh0niqv6xxi3lz77-gnumake-musl-4.4.1.drv",["out"]),("/nix/store/haldh962ah38jwv0i8f72nr68nn7vw9r-Python-3.14.4.tar.xz.drv",["out"]),("/nix/store/nfqnml0i1gf4ndlnmzrizzl726phcpv8-gnupatch-2.5.9.drv",["out"]),("/nix/store/pk5cfasvyzvfy7mkvxjb6llpbma6lh4f-gnutar-1.35.drv",["out"]),("/nix/store/pya9pjq15flb193cszdifpjqlji7jjgc-zlib-1.3.2.drv",["out"]),("/nix/store/ri59ab1rjfz350rr5b310v4rx3kybljh-gnused-4.2.drv",["out"]),("/nix/store/vgvgcv9flci501zlg4499bxxv6l39lz2-musl-1.2.6.drv",["out"]),("/nix/store/zygspa3c9cxvd4bym18yn6hahpvg48a1-gnugrep-2.4.drv",["out"])],["/nix/store/70acbfgbz5cxsx4sqzcnj8qaqhb4i9ay-bash-builder.sh","/nix/store/jqin2kzvzrvi30cxda5zp7qz1fanmz7v-no-ldconfig.patch"],"i686-linux","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash",["-e","/nix/store/70acbfgbz5cxsx4sqzcnj8qaqhb4i9ay-bash-builder.sh"],[("PATH","/nix/store/1sn54z1pbi02669jkbl09q11vn2b5zkv-gcc-15.2.0/bin:/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/bin:/nix/store/vsgslsdli52psy9c7jy5lpx2lz2gsxxl-binutils-2.46.0/bin:/nix/store/g71r6cvl1sak7a5a1x052nb6b4bql5py-gnumake-musl-4.4.1/bin:/nix/store/rmg3bi9pkk7y7pjcr0z9km5bngpkmbw8-gnupatch-2.5.9/bin:/nix/store/cmpkz5yy4rv0c0ny6xrzgckfsdlrllz2-gnused-4.2/bin:/nix/store/8iw88kcninwzwbk02xms6cr1q7yj3fx7-gnugrep-2.4/bin:/nix/store/0xbljs2y42ci87jnnnn9w2iavkrrs2qa-gawk-5.3.2/bin:/nix/store/s8d31db59vif5f37425530fybgcwcxbs-diffutils-3.8/bin:/nix/store/8f4w9gcmf39dr93f6h70nyfkhk6basdn-findutils-4.10.0/bin:/nix/store/448367w4w7mjsad0qqvd8m7qrpnsc0am-gnutar-1.35/bin:/nix/store/jf5kd2s17bp88w9axwz2525206sw4shq-xz-5.8.3/bin:/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin:/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10/bin"),("SHELL","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("buildCommand","# Unpack\ntar xf /nix/store/vwj66jmx32xbw97zwbajmncp028kb93a-Python-3.14.4.tar.xz\ncd Python-3.14.4\n\n# Patch\npatch -Np1 -i /nix/store/jqin2kzvzrvi30cxda5zp7qz1fanmz7v-no-ldconfig.patch\n\n# Configure\nexport CC=musl-gcc\nexport C_INCLUDE_PATH=\"/nix/store/99infkfwi9vhk8fgzh5z077si192xil8-zlib-1.3.2/include\"\nexport LIBRARY_PATH=\"/nix/store/99infkfwi9vhk8fgzh5z077si192xil8-zlib-1.3.2/lib\"\nexport LDFLAGS=\"-Wl,-rpath,/nix/store/99infkfwi9vhk8fgzh5z077si192xil8-zlib-1.3.2/lib -L/nix/store/99infkfwi9vhk8fgzh5z077si192xil8-zlib-1.3.2/lib\"\nexport LD_LIBRARY_PATH=\"$LIBRARY_PATH\"\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --disable-test-modules \\\n  --without-ensurepip \\\n  --without-static-libpython\n\n# Build\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install\n\n# Remove lib-dynload extension modules not needed for glibc's build scripts.\n# glibc uses Python only for scripts that import: os, re, subprocess, argparse,\n# pathlib, collections, tempfile.  Following the import chain:\n#   subprocess -> selectors -> math, select, fcntl, _posixsubprocess\n#   pathlib -> grp\n#   tempfile -> random -> _random, bisect -> _bisect\n# Everything else in lib-dynload is dead weight in the bootstrap context.\nfind $out/lib/python*/lib-dynload -name '*.so' \\\n  ! -name '_bisect*' \\\n  ! -name '_posixsubprocess*' \\\n  ! -name '_random*' \\\n  ! -name 'fcntl*' \\\n  ! -name 'grp*' \\\n  ! -name 'math*' \\\n  ! -name 'select*' \\\n  -delete\n\nrm -rf \\\n  $out/lib/python*/ensurepip \\\n  $out/lib/python*/idlelib \\\n  $out/lib/python*/site-packages \\\n  $out/lib/python*/test \\\n  $out/lib/python*/tkinter \\\n  $out/lib/python*/turtledemo \\\n  $out/share/man\n\nrm -f $out/bin/idle* $out/bin/pip*\nfind $out/lib/python* -type d -name __pycache__ -prune -exec rm -rf {} +\nstrip --strip-unneeded $out/bin/python3.14 $out/lib/python*/lib-dynload/*.so || true\n"),("builder","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("name","python-3.14.4"),("out","/nix/store/dazm0w6r8bignl7mcrw76877nyxpxqkb-python-3.14.4"),("passAsFile","buildCommand"),("pname","python"),("system","i686-linux"),("version","3.14.4")])