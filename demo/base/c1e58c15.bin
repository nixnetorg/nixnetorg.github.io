Derive([("doc","/nix/store/a2zxrn27qc3zlzn0x5rcchg4pw4kk7kh-gettext-1.0-doc","",""),("info","/nix/store/z3m1nwqvc1n98gsva58mdc5qaid1nmp1-gettext-1.0-info","",""),("man","/nix/store/hgf4dhnifadm6kc2i54ih4a0q28b97ki-gettext-1.0-man","",""),("out","/nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0","","")],[("/nix/store/00yfr3x8lkhmnj8cvrkqivxjkr8idgbk-stdenv-linux.drv",["out"]),("/nix/store/59ycc3dkm4m39prrx61sh6ga4mm6ha8r-update-autotools-gnu-config-scripts-hook.drv",["out"]),("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["dev","out"]),("/nix/store/dd59r1907l141wpn2ccjwwk3pgb7jxqk-gettext-1.0.tar.gz.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash","/nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__structuredAttrs",""),("buildInputs","/nix/store/q5kfxqrvwnw6qds7kglmf297da10hzbx-bash-5.3p9-dev"),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("cmakeFlags",""),("configureFlags","--disable-csharp"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("doCheck",""),("doInstallCheck",""),("doc","/nix/store/a2zxrn27qc3zlzn0x5rcchg4pw4kk7kh-gettext-1.0-doc"),("enableParallelBuilding","1"),("enableParallelChecking",""),("enableParallelInstalling","1"),("gettextNeedsLdflags",""),("info","/nix/store/z3m1nwqvc1n98gsva58mdc5qaid1nmp1-gettext-1.0-info"),("man","/nix/store/hgf4dhnifadm6kc2i54ih4a0q28b97ki-gettext-1.0-man"),("mesonFlags",""),("name","gettext-1.0"),("nativeBuildInputs","/nix/store/dydzn0lfnvyjzn3xgvk13r6bnlway9fg-update-autotools-gnu-config-scripts-hook"),("out","/nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0"),("outputs","out man doc info"),("patches","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff /nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"),("pname","gettext"),("postPatch","# Older versions of gettext come with a copy of `extern-inline.m4` that is not compatible with clang 18.\n# When a project uses gettext + autoreconfPhase, autoreconfPhase will invoke `autopoint -f`, which will\n# replace whatever (probably compatible) version of `extern-inline.m4` with one that probalby won’t work\n# because `autopoint` will copy the autoconf macros from the project’s required version of gettext.\n# Fixing this requires replacing all the older copies of the problematic file with a new one.\n#\n# This is ugly, but it avoids requiring workarounds in every package using gettext and autoreconfPhase.\ndeclare -a oldFiles=($(tar tf gettext-tools/autotools/archive.dir.tar | grep '^gettext-0\\.[19].*/extern-inline.m4'))\noldFilesDir=$(mktemp -d)\nfor oldFile in \"${oldFiles[@]}\"; do\n  mkdir -p \"$oldFilesDir/$(dirname \"$oldFile\")\"\n  cp -a gettext-tools/gnulib-m4/extern-inline.m4 \"$oldFilesDir/$oldFile\"\ndone\ntar uf gettext-tools/autotools/archive.dir.tar --owner=0 --group=0 --numeric-owner -C \"$oldFilesDir\" \"${oldFiles[@]}\"\n\nsubstituteAllInPlace gettext-runtime/src/gettext.sh.in\nsubstituteInPlace gettext-tools/projects/KDE/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/projects/GNOME/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/src/project-id --replace \"/bin/pwd\" pwd\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("setupHooks","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash /nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh"),("src","/nix/store/n4lwy41bnpq1fsqsrf5fac3m7vmhk6sr-gettext-1.0.tar.gz"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","1.0")])