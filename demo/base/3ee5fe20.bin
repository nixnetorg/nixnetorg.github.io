Derive([("out","/nix/store/7q95zf345a1fzqg770wmasahfi7l6pfc-heirloom-devtools-070527-builder","","")],[("/nix/store/0ibwnm5f9q4r7j2d6v3239wgk59yn0xx-heirloom-devtools-070527.tar.bz2.drv",["out"]),("/nix/store/6c9czp98fd8gahfd13lkqhpq30ygckqm-lex_remove_wchar.patch.drv",["out"]),("/nix/store/8b67q6cv53n3gk1761nx2xbh85lscm4a-kaem-1.9.1.drv",["out"]),("/nix/store/9shlvqdb0qbpgs7mibfn17v7c4lzwfmf-tinycc-mes-libs-unstable-2025-12-03.drv",["out"]),("/nix/store/m7qhh4k03ymh4myrj8nnanzgr2pcx5pp-yacc_remove_wchar.patch.drv",["out"]),("/nix/store/pz1z6acpb6x0gyrbysy9rs47vhn4qgzf-mescc-tools-extra-1.9.1.drv",["out"])],["/nix/store/m48r7nsm8wgjy69jg442vc7jjdfmcnl7-write-text-file.kaem"],"i686-linux","/nix/store/hqv8h6w14khjb53g28mqk2kb2d58x27h-kaem-1.9.1/bin/kaem",["--verbose","--strict","--file","/nix/store/m48r7nsm8wgjy69jg442vc7jjdfmcnl7-write-text-file.kaem"],[("PATH","/nix/store/wrv08hp23d4r3y7im82mz9wagncycpzi-mescc-tools-extra-1.9.1/bin"),("builder","/nix/store/hqv8h6w14khjb53g28mqk2kb2d58x27h-kaem-1.9.1/bin/kaem"),("destination",""),("destinationDir","."),("name","heirloom-devtools-070527-builder"),("out","/nix/store/7q95zf345a1fzqg770wmasahfi7l6pfc-heirloom-devtools-070527-builder"),("passAsFile","text"),("system","i686-linux"),("text","# Unpack\nunbz2 --file /nix/store/ac1m39bhygw779xmvmk1mz8skzrm8rck-heirloom-devtools-070527.tar.bz2 --output heirloom-devtools.tar\nuntar --file heirloom-devtools.tar\nrm heirloom-devtools.tar\nbuild=${NIX_BUILD_TOP}/heirloom-devtools-070527\ncd ${build}\n\n# Patch\npatch -Np0 -i /nix/store/ksh90cdrd659xxq98ji0lzl1qww3f40p-yacc_remove_wchar.patch\npatch -Np0 -i /nix/store/0cq14hnqsy1vzdk7zgmihzac8ysvzrki-lex_remove_wchar.patch\n\n\n# Build yacc\ncd yacc\nmake -f Makefile.mk \\\n  CC=\"tcc -B /nix/store/0fks57d0gyhk6g3niadg55mrxhgfslsq-tinycc-mes-libs-unstable-2025-12-03/lib\" \\\n  AR=\"tcc -ar\" \\\n  CFLAGS=\"-DMAXPATHLEN=4096 -DEILSEQ=84 -DMB_LEN_MAX=100\" \\\n  LDFLAGS=\"-lgetopt\" \\\n  RANLIB=true \\\n  LIBDIR=${out}/lib\n\n# Install yacc\ninstall -D yacc ${out}/bin/yacc\ninstall -Dm 444 liby.a ${out}/lib/liby.a\ninstall -Dm 444 yaccpar ${out}/lib/yaccpar\n\n# Make yacc available to lex\nPATH=\"${out}/bin:${PATH}\"\n\n# Build lex\ncd ../lex\nmake -f Makefile.mk \\\n  CC=\"tcc -B /nix/store/0fks57d0gyhk6g3niadg55mrxhgfslsq-tinycc-mes-libs-unstable-2025-12-03/lib\" \\\n  AR=\"tcc -ar\" \\\n  CFLAGS=\"-DEILSEQ=84 -DMB_LEN_MAX=100\" \\\n  LDFLAGS=\"-lgetopt\" \\\n  RANLIB=true \\\n  LIBDIR=${out}/lib\n\n# Install lex\ninstall -D lex ${out}/bin/lex\ninstall -Dm 444 ncform ${out}/lib/lex/ncform\ninstall -Dm 444 nceucform ${out}/lib/lex/nceucform\ninstall -Dm 444 nrform ${out}/lib/lex/nrform\ninstall -Dm 444 libl.a ${out}/lib/libl.a\n")])