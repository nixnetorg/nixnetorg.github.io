ore/73bwxvdmw63kgb1x27nqr7hh227nz04g-virtualenv-permissions.patch","/nix/store/gx4pa1m75g8rrrggj7gi3bg38m4lg3q5-sitecustomize.py","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/lpfs02z2i2hamz9f50p4bz6v0fs0600j-mimetypes.patch","/nix/store/r989dk196nl9frhnfsa1lb7knhbyjxw6-separate-debug-info.sh","/nix/store/s5myj3ybdn7wrsfpydj48mm24vnvw6bc-no-ldconfig.patch","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__json","{\"CPPFLAGS\":\"-I/nix/store/gfm702l7vmwyfhifm2l298rd09scbkm2-bzip2-1.0.8-dev/include -I/nix/store/gsqvr7dpdg0pb89p0cgpjgbb90ac48z4-libffi-3.5.2-dev/include -I/nix/store/ahz0qh9arcr8pps4hva9yczlppwqf66w-util-linux-minimal-2.42-dev/include -I/nix/store/k3zkv9g55zgfm7facwjzp63gikqnh78m-ncurses-6.6-dev/include -I/nix/store/76n4n9df9kc5jn804gimhz1d9drc5fhh-xz-5.8.3-dev/include -I/nix/store/wdkjfvpavi712wsgdzbvgkdc6s9bsfcm-zlib-1.3.2-dev/include -I/nix/store/45kp2zmmhrwys6fiyxm9alqh8dsjq7af-openssl-3.6.2-dev/include -I/nix/store/aggz2r4ifm3mqk1h7j5klc93lxb9817q-sqlite-3.51.2-dev/include -I/nix/store/3sww82cnylsn2d561321gf6nr9bdmclf-mpdecimal-4.0.1-dev/include -I/nix/store/l9qzw3nv3q9z1h7y5vl926rb3r42ydy9-expat-2.8.0-dev/include -I/nix/store/b3ax3ac9c9rwnyfhq0lbvf14s9imfc2c-bluez-headers-5.86/include -I/nix/store/chgwvagmr3k9v9bm596b1g5hgrmjkmwp-tzdata-2026b-dev/include -I/nix/store/6k4zi2xf32j7b0f1c94hqjc40ib5vl1z-gdbm-1.26-dev/include -I/nix/store/9d34isir7bsgdssd4laxwfw2yr5c0wh6-readline-8.3p3-dev/include\",\"LDFLAGS\":\"-L/nix/store/9w00jalqz1ywr764zzs0ws8zikxay2hh-bzip2-1.0.8/lib -L/nix/store/lnrxjfpsvva7akz64dfl0p55m2nah9dk-libffi-3.5.2/lib -L/nix/store/q9b4m0xi563va38ga3mxly4zpf7cg9c1-util-linux-minimal-2.42-lib/lib -L/nix/store/x18va8gs4xa93hjvsdlgnk6hbmzc0dqc-ncurses-6.6/lib -L/nix/store/n3d39vxr