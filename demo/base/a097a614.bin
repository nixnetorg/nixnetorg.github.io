Derive([("dev","/nix/store/k3zkv9g55zgfm7facwjzp63gikqnh78m-ncurses-6.6-dev","",""),("man","/nix/store/95b0f67x1zcrs2vxvclbxnjskhdma29p-ncurses-6.6-man","",""),("out","/nix/store/x18va8gs4xa93hjvsdlgnk6hbmzc0dqc-ncurses-6.6","","")],[("/nix/store/00yfr3x8lkhmnj8cvrkqivxjkr8idgbk-stdenv-linux.drv",["out"]),("/nix/store/0wi1n87nfv5l933hyf3qna8g59p5vcll-ncurses-6.6.tar.gz.drv",["out"]),("/nix/store/59ycc3dkm4m39prrx61sh6ga4mm6ha8r-update-autotools-gnu-config-scripts-hook.drv",["out"]),("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/nzbjj9r2z8ky1va7x05c95h8kvwv6pq8-pkg-config-wrapper-0.29.2.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__structuredAttrs",""),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("cmakeFlags",""),("configureFlags","--with-shared --enable-pc-files --enable-symlinks --with-manpage-format=normal --disable-stripping --with-versioned-syms --without-debug cf_cv_type_of_bool=bool --build=i686-unknown-linux-gnu --host=i686-unknown-linux-gnu"),("configurePlatforms","build host"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("dev","/nix/store/k3zkv9g55zgfm7facwjzp63gikqnh78m-ncurses-6.6-dev"),("doCheck",""),("doInstallCheck",""),("enableParallelBuilding","1"),("enableParallelChecking","1"),("enableParallelInstalling","1"),("man","/nix/store/95b0f67x1zcrs2vxvclbxnjskhdma29p-ncurses-6.6-man"),("mesonFlags",""),("name","ncurses-6.6"),("nativeBuildInputs","/nix/store/dydzn0lfnvyjzn3xgvk13r6bnlway9fg-update-autotools-gnu-config-scripts-hook /nix/store/x17mq9srwk8lxv0797r39d4k3zbrzz0n-pkg-config-wrapper-0.29.2"),("out","/nix/store/x18va8gs4xa93hjvsdlgnk6hbmzc0dqc-ncurses-6.6"),("outputs","out dev man"),("patches",""),("pname","ncurses"),("postInstall","rm \"$out\"/lib/*.a\n# Determine what suffixes our libraries have\nsuffix=\"$(awk -F': ' 'f{print $3; f=0} /default library suffix/{f=1}' config.log)\"\nlibs=\"$(ls $dev/lib/pkgconfig | tr ' ' '\\n' | sed \"s,\\(.*\\)$suffix\\.pc,\\1,g\")\"\nsuffixes=\"$(echo \"$suffix\" | awk '{for (i=1; i < length($0); i++) {x=substr($0, i+1, length($0)-i); print x}}')\"\n\n# Get the path to the config util\ncfg=$(basename $dev/bin/ncurses*-config)\n\n# symlink the full suffixed include directory\nln -svf . $dev/include/ncurses$suffix\n\nfor newsuffix in $suffixes \"\"; do\n  # Create a non-abi versioned config util links\n  ln -svf $cfg $dev/bin/ncurses$newsuffix-config\n\n  # Allow for end users who #include <ncurses?w/*.h>\n  ln -svf . $dev/include/ncurses$newsuffix\n\n  for library in $libs; do\n    for dylibtype in so dll dylib; do\n      if [ -e \"$out/lib/lib${library}$suffix.$dylibtype\" ]; then\n        ln -svf lib${library}$suffix.$dylibtype $out/lib/lib$library$newsuffix.$dylibtype\n        ln -svf lib${library}$suffix.$dylibtype.6 $out/lib/lib$library$newsuffix.$dylibtype.6\n        if [ \"ncurses\" = \"$library\" ]\n        then\n          # make libtinfo symlinks\n          ln -svf lib${library}$suffix.$dylibtype $out/lib/libtinfo$newsuffix.$dylibtype\n          ln -svf lib${library}$suffix.$dylibtype.6 $out/lib/libtinfo$newsuffix.$dylibtype.6\n        fi\n      fi\n    done\n    for statictype in a dll.a la; do\n      if [ -e \"$out/lib/lib${library}$suffix.$statictype\" ]; then\n        ln -svf lib${library}$suffix.$statictype $out/lib/lib$library$newsuffix.$statictype\n        if [ \"ncurses\" = \"$library\" ]\n        then\n          # make libtinfo symlinks\n          ln -svf lib${library}$suffix.$statictype $out/lib/libtinfo$newsuffix.$statictype\n        fi\n      fi\n    done\n    ln -svf ${library}$suffix.pc $dev/lib/pkgconfig/$library$newsuffix.pc\n  done\ndone\n\n# add pkg-config aliases for libraries that are built-in to libncurses(w)\nfor library in tinfo tic; do\n  for suffix in \"\" w; do\n    ln -svf ncurses$suffix.pc $dev/lib/pkgconfig/$library$suffix.pc\n  done\ndone\n\n# move some utilities to $bin\n# these programs are used at runtime and don't really belong in $dev\nmoveToOutput \"bin/clear\" \"$out\"\nmoveToOutput \"bin/reset\" \"$out\"\nmoveToOutput \"bin/tabs\" \"$out\"\nmoveToOutput \"bin/tic\" \"$out\"\nmoveToOutput \"bin/tput\" \"$out\"\nmoveToOutput \"bin/tset\" \"$out\"\nmoveToOutput \"bin/captoinfo\" \"$out\"\nmoveToOutput \"bin/infotocap\" \"$out\"\nmoveToOutput \"bin/infocmp\" \"$out\"\n"),("postPatch","sed -i '1i #include <stdbool.h>' include/curses.h.in\n"),("preConfigure","export PKG_CONFIG_LIBDIR=\"$dev/lib/pkgconfig\"\nmkdir -p \"$PKG_CONFIG_LIBDIR\"\nconfigureFlagsArray+=(\n  \"--libdir=$out/lib\"\n  \"--includedir=$dev/include\"\n  \"--bindir=$dev/bin\"\n  \"--mandir=$man/share/man\"\n  \"--with-pkg-config-libdir=$PKG_CONFIG_LIBDIR\"\n)\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("separateDebugInfo",""),("setOutputFlags",""),("src","/nix/store/1hkx09zxzwwhqwnr5rdi7r2v7jbiki00-ncurses-6.6.tar.gz"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","6.6")])