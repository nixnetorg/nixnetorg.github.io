n:/nix/store/rmg3bi9pkk7y7pjcr0z9km5bngpkmbw8-gnupatch-2.5.9/bin:/nix/store/cmpkz5yy4rv0c0ny6xrzgckfsdlrllz2-gnused-4.2/bin:/nix/store/8iw88kcninwzwbk02xms6cr1q7yj3fx7-gnugrep-2.4/bin:/nix/store/0xbljs2y42ci87jnnnn9w2iavkrrs2qa-gawk-5.3.2/bin:/nix/store/s8d31db59vif5f37425530fybgcwcxbs-diffutils-3.8/bin:/nix/store/8f4w9gcmf39dr93f6h70nyfkhk6basdn-findutils-4.10.0/bin:/nix/store/hyx7fbs539fjk2v0vvac421a4l5vpkpb-gnutar-musl-1.12/bin:/nix/store/1dwbpwfrydg8ayw0bin93gnkgbdxcgi7-gzip-1.2.4/bin:/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin:/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10/bin"),("SHELL","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("buildCommand","# Unpack\ntar xzf /nix/store/69z84pzjkwms0cxrmjrnrzqan901pa6f-gcc-core-4.6.4.tar.gz\ntar xzf /nix/store/4a1pv7pgnbvzhk768i2lfw3azlygawqz-gcc-g++-4.6.4.tar.gz\ntar xzf /nix/store/7rsy9kwa1jvsil21avgqgfnjfvsc4snq-gmp-4.3.2.tar.gz\ntar xzf /nix/store/ld9r1azyxbiqcp0frrndjv9ih48icif3-mpfr-2.4.2.tar.gz\ntar xzf /nix/store/x1j4kyqq4x7lqrjnif1mkdqr06blr3i4-mpc-1.0.3.tar.gz\ncd gcc-4.6.4\n\nln -s ../gmp-4.3.2 gmp\nln -s ../mpfr-2.4.2 mpfr\nln -s ../mpc-1.0.3 mpc\n\n# Patch\npatch -Np1 -i /nix/store/7bqlyrbj1r9ddcmm825g9zzhrgwxy9fw-no-system-headers.patch\n# doesn't recognise musl\nsed -i 's|\"os/gnu-linux\"|\"os/generic\"|' libstdc++-v3/configure.host\n\n# Configure\nexport CC=\"gcc -Wl,-dynamic-linker -Wl,/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/lib/libc.so\"\nexport CFLAGS_FOR_TARGET=\"-Wl,-dynamic-linker -Wl,/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/lib/libc.so\"\nexport C_INCLUDE_PATH=\"/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/include\"\nexport CPLUS_INCLUDE_PATH=\"$C_INCLUDE_PATH\"\nexport LIBRARY_PATH=\"/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/lib\"\n\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --with-native-system-header-dir=/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6/include \\\n  --with-build-sysroot=/nix/store/nj5lcmdvk48qdqyybfbns0pv1p128dp6-musl-1.2.6 \\\n  --enable-languages=c,c++ \\\n  --enable-checking=release \\\n  --disable-bootstrap \\\n  --disable-dependency-tracking \\\n  --disable-libgomp \\\n  --disable-libmudflap \\\n  --disable-libquadmath \\\n  --disable-libssp \\\n  --disable-libstdcxx-pch \\\n  --disable-lto \\\n  --disable-multilib \\\n  --disable-nls\n\n# Build\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install-strip\n"),("builder","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("name","gcc-cxx-4.6.4"),("out","/nix/store/6jkwibypn11zx9iflbfzzj880pr1as5f-gcc-cxx-4.6.4"),("passAsFile","buildCommand"),("pname","gcc-cxx"),("system","i686-linux"),("version","4.6.4")])