p-2.4/bin:/nix/store/0xbljs2y42ci87jnnnn9w2iavkrrs2qa-gawk-5.3.2/bin:/nix/store/s8d31db59vif5f37425530fybgcwcxbs-diffutils-3.8/bin:/nix/store/8f4w9gcmf39dr93f6h70nyfkhk6basdn-findutils-4.10.0/bin:/nix/store/448367w4w7mjsad0qqvd8m7qrpnsc0am-gnutar-1.35/bin:/nix/store/1dwbpwfrydg8ayw0bin93gnkgbdxcgi7-gzip-1.2.4/bin:/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin:/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10/bin"),("SHELL","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("buildCommand","# Unpack\ntar xf /nix/store/0avnvyc7pkcr4pjqws7hwpy87m6wlnjc-make-4.4.1.tar.gz\ncd make-4.4.1\n\n# Patch\npatch -Np1 -i /nix/store/2k52bklbjhhq47dn35gm833vlh06fgfn-0001-No-impure-bin-sh.patch\npatch -Np1 -i /nix/store/6cc64ayl3fd2nc28ffw47cqsqi2bg1sn-0002-remove-impure-dirs.patch\n\n# Configure\n#\n# Use std=gnu17 to avoid issue GCC 15.2.0 incompatibility.\n# There is no newer release of gnumake available right now.\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --disable-dependency-tracking \\\n  CC=musl-gcc \\\n  CFLAGS=\"-static -std=gnu17\"\n\n# Build\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install-strip\n"),("builder","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("name","gnumake-static-4.4.1"),("out","/nix/store/4bw003s4ngy149dwwy2ajkhc3nzz9qh1-gnumake-static-4.4.1"),("passAsFile","buildCommand"),("pname","gnumake-static"),("system","i686-linux"),("version","4.4.1")])