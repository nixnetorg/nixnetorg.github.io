Derive([("out","/nix/store/whfjddffvlqpcba6p53yzx44h72yyp1k-write_run_json","","")],[("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/i2iy5vhwb7g1pv5svyyzhpcpagwvwwdv-stdenv-linux.drv",["out"]),("/nix/store/rrwx4izf1zb8k7394wkhk82xcy17g33q-coreutils-9.11.drv",["out"]),("/nix/store/vj2j7dn6fhmsbcbvk1920z9lk7sbmchh-busybox-mini.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("NIX_MAIN_PROGRAM","write_run_json"),("__structuredAttrs",""),("allowSubstitutes","1"),("buildCommand","target=$out$destination\nmkdir -p \"$(dirname \"$target\")\"\n\nif [ -e \"$textPath\" ]; then\n  mv \"$textPath\" \"$target\"\nelse\n  printf \"%s\" \"$text\" > \"$target\"\nfi\n\nif [ -n \"$executable\" ]; then\n  chmod +x \"$target\"\nfi\n\neval \"$checkPhase\"\n"),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("checkPhase","runHook preCheck\n/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash -n -O extglob \"$target\"\n\nrunHook postCheck\n"),("cmakeFlags",""),("configureFlags",""),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("destination","/bin/write_run_json"),("doCheck",""),("doInstallCheck",""),("executable","1"),("mesonFlags",""),("name","write_run_json"),("nativeBuildInputs",""),("out","/nix/store/whfjddffvlqpcba6p53yzx44h72yyp1k-write_run_json"),("outputs","out"),("passAsFile","text"),("patches",""),("preferLocalBuild",""),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("stdenv","/nix/store/5wly0ig1rwgv67m1dr8gz1655drp3cmn-stdenv-linux"),("strictDeps",""),("system","i686-linux"),("text","#!/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\nset -o errexit\nset -o nounset\nset -o pipefail\n\nexport PATH=\"/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin:/nix/store/6c0fjwgaxpnnlk5yna14kpan6f0442g3-busybox-mini/bin:$PATH\"\n\n#!/usr/bin/env bash\n# Writes run.json in the current directory with host metadata (CPU, memory, kernel, sysctl)\n# and a reference to the Nix store path of the experiment. Used to annotate testbed runs.\nset -euo pipefail\n\nstore_path=\"$1\"\ntimestamp=\"$(date -Iseconds)\"\n\ncpu_model=\"$(grep -m1 'model name' /proc/cpuinfo | cut -d: -f2 | xargs || echo unknown)\"\ncpu_cores=\"$(nproc)\"\ncpu_governor=\"$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo unknown)\"\ncpu_freq_khz=\"$(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq 2>/dev/null || echo 0)\"\nturbo_disabled=\"$(cat /sys/devices/system/cpu/intel_pstate/no_turbo 2>/dev/null || echo unknown)\"\n\nmem_total_kb=\"$(grep MemTotal /proc/meminfo | awk '{print $2}')\"\nmem_total_mb=\"$(( mem_total_kb / 1024 ))\"\nthp=\"$(cat /sys/kernel/mm/transparent_hugepage/enabled 2>/dev/null | sed -n 's/.*\\[\\(.*\\)\\].*/\\1/p' || echo unknown)\"\n\nload=\"$(cut -d' ' -f1-3 /proc/loadavg)\"\n\nkernel=\"$(uname -r)\"\nkernel_full=\"$(uname -srvm)\"\narch=\"$(uname -m)\"\nhostname=\"$(uname -n)\"\n\n# Dump all scalar /proc/sys/net values, skipping per-interface conf/ and neigh/ subtrees.\n# Tries to parse value as JSON number/array, falls back to quoted string.\nsysctl_json() {\n  local first=1\n  while IFS= read -r -d '' f; do\n    local key val json_val\n    key=\"${f#/proc/sys/}\"\n    key=\"${key//\\//.}\"\n    val=\"$(cat \"$f\" 2>/dev/null)\" || continue\n    # Try integer\n    if [[ \"$val\" =~ ^-?[0-9]+$ ]]; then\n      json_val=\"$val\"\n    # Try whitespace-separated integers (triple like tcp_rmem)\n    elif [[ \"$val\" =~ ^-?[0-9]+([[:space:]]+-?[0-9]+)+$ ]]; then\n      json_val=\"[$(echo \"$val\" | xargs | tr ' ' ',')]\"\n    else\n      # Escape backslashes and double quotes, strip newlines\n      val=\"${val//\\\\/\\\\\\\\}\"\n      val=\"${val//\\\"/\\\\\\\"}\"\n      val=\"${val//$'\\n'/ }\"\n      json_val=\"\\\"$val\\\"\"\n    fi\n    [ \"$first\" -eq 1 ] && first=0 || printf ','\n    printf '\\n      \"%s\": %s' \"$key\" \"$json_val\"\n  done < <(find /proc/sys/net \\\n    -not \\( -path '*/conf/*' -prune \\) \\\n    -not \\( -path '*/neigh/*' -prune \\) \\\n    -not \\( -path '*/nf_log/*' -prune \\) \\\n    -type f -print0 | sort -z)\n}\n\ncat > run.json <<EOF\n{\n  \"experiment\": \"${store_path}\",\n  \"timestamp\": \"${timestamp}\",\n  \"host\": {\n    \"hostname\": \"${hostname}\",\n    \"kernel\": \"${kernel}\",\n    \"kernel_full\": \"${kernel_full}\",\n    \"arch\": \"${arch}\",\n    \"load_avg\": \"${load}\",\n    \"cpu\": {\n      \"model\": \"${cpu_model}\",\n      \"cores\": ${cpu_cores},\n      \"governor\": \"${cpu_governor}\",\n      \"freq_khz\": ${cpu_freq_khz},\n      \"turbo_disabled\": \"${turbo_disabled}\"\n    },\n    \"mem\": {\n      \"total_mb\": ${mem_total_mb},\n      \"transparent_hugepages\": \"${thp}\"\n    },\n    \"sysctl\": {$(sysctl_json)\n    }\n  }\n}\nEOF\n\n")])