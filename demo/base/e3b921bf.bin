iffutils-3.8/bin:/nix/store/hyx7fbs539fjk2v0vvac421a4l5vpkpb-gnutar-musl-1.12/bin:/nix/store/jf5kd2s17bp88w9axwz2525206sw4shq-xz-5.8.3/bin:/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin:/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10/bin"),("SHELL","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("buildCommand","# Unpack\ncp /nix/store/agzpvgbj5sk61kq8z5zwggcn4vd6f0ij-binutils-2.46.0.tar.xz binutils.tar.xz\nunxz binutils.tar.xz\ntar xf binutils.tar\nrm binutils.tar\ncd binutils-2.46.0\n\n# Patch\npatch -Np1 -i /nix/store/sqbhaaayam0xw3a3164ks1vvbrdhl9vq-deterministic.patch\npatch -Np1 -i /nix/store/1bs8wn3nwiji4vcwfzxpncwsa1pnh404-fix-tinycc-attribute.patch\nsed -i 's|/bin/sh|/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash|' \\\n  missing install-sh mkinstalldirs\n# see libtool's 74c8993c178a1386ea5e2363a01d919738402f30\nsed -i 's/| \\$NL2SP/| sort | $NL2SP/' ltmain.sh\n# alias makeinfo to true\nmkdir aliases\nln -s /nix/store/pp0yi0xvymmfqv3nwbbh0rfglbs5zqih-bootstrap-coreutils-5.0/bin/true aliases/makeinfo\nexport PATH=\"$(pwd)/aliases/:$PATH\"\n\n# Configure\nexport CC=\"tcc -B /nix/store/igkpl9ifkvqpxa20i378f300pvpqc5yj-tinycc-musl-unstable-2025-12-03-libs/lib\"\nexport AR=\"tcc -ar\"\nexport lt_cv_sys_max_cmd_len=32768\n\nexport CFLAGS=\"-D__LITTLE_ENDIAN__=1\"\nbash ./configure --prefix=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9 --build=i686-unknown-linux-gnu --host=i686-unknown-linux-gnu --with-sysroot=/ --disable-dependency-tracking --disable-nls --enable-deterministic-archives --disable-gprofng --enable-new-dtags --with-lib-path=:\n\n# Build\nmake -j $NIX_BUILD_CORES all-libiberty all-gas all-bfd all-libctf all-zlib all-gprof\nmake all-ld # race condition on ld/.deps/ldwrite.Po, serialize\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install\n\n# gprof/addr2line/elfedit + man pages are unused downstream.\nrm -f $out/bin/gprof $out/bin/addr2line $out/bin/elfedit\nrm -rf $out/share/info $out/share/man\n"),("builder","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("name","binutils-2.46.0"),("out","/nix/store/vsgslsdli52psy9c7jy5lpx2lz2gsxxl-binutils-2.46.0"),("passAsFile","buildCommand"),("pname","binutils"),("system","i686-linux"),("version","2.46.0")])