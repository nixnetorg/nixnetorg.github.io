${M2} --architecture x86 \
  -f ${m2libc}/sys/types.h \
  -f ${m2libc}/stddef.h \
  -f ${m2libc}/sys/utsname.h \
  -f ${m2libc}/x86/linux/fcntl.c \
  -f ${m2libc}/fcntl.c \
  -f ${m2libc}/x86/linux/unistd.c \
  -f ${m2libc}/x86/linux/sys/stat.c \
  -f ${m2libc}/ctype.c \
  -f ${m2libc}/stdlib.c \
  -f ${m2libc}/stdarg.h \
  -f ${m2libc}/stdio.h \
  -f ${m2libc}/stdio.c \
  -f ${m2libc}/string.c \
  -f ${m2libc}/bootstrappable.c \
  -f ${src}/mescc-tools-extra/chmod.c \
  --debug \
  -o chmod.M1

${blood-elf-0} --little-endian   -f chmod.M1 -o chmod-footer.M1

${M1} --architecture x86 \
  --little-endian \
  -f ${m2libc}/x86/x86_defs.M1 \
  -f ${m2libc}/x86/libc-full.M1 \
  -f chmod.M1 \
  -f chmod-footer.M1 \
  -o chmod.hex2

${hex2} --architecture x86 \
  --little-endian \
  -f ${m2libc}/x86/ELF-x86-debug.hex2 \
  -f chmod.hex2 \
  --base-address 0x08048000 \
  -o ${out}
