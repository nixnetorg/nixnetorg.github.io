Derive([("out","/nix/store/1b5frx0a86v8q858i0281bpvfbwb29f8-testbed-wrapped","","")],[("/nix/store/0qmz5gpds06yj3lf1zrqlay3km8vsfw3-write_run_json.drv",["out"]),("/nix/store/9rl0xari0phqwz4xvs2qn5p5bn9376b2-iputils-20250605.drv",["out"]),("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/i2iy5vhwb7g1pv5svyyzhpcpagwvwwdv-stdenv-linux.drv",["out"]),("/nix/store/nli0vg7g3bnbxl1ybjas59bwswbdyg51-util-linux-minimal-2.42.drv",["bin"]),("/nix/store/rrwx4izf1zb8k7394wkhk82xcy17g33q-coreutils-9.11.drv",["out"]),("/nix/store/vj2j7dn6fhmsbcbvk1920z9lk7sbmchh-busybox-mini.drv",["out"]),("/nix/store/vxy70llxjil7w0wp1nz2lcv9vr781cl5-iproute2-7.0.0.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__structuredAttrs",""),("allowSubstitutes",""),("buildCommand","target=$out$destination\nmkdir -p \"$(dirname \"$target\")\"\n\nif [ -e \"$textPath\" ]; then\n  mv \"$textPath\" \"$target\"\nelse\n  printf \"%s\" \"$text\" > \"$target\"\nfi\n\nif [ -n \"$executable\" ]; then\n  chmod +x \"$target\"\nfi\n\neval \"$checkPhase\"\n"),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("checkPhase",""),("cmakeFlags",""),("configureFlags",""),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("destination",""),("doCheck",""),("doInstallCheck",""),("executable","1"),("mesonFlags",""),("name","testbed-wrapped"),("nativeBuildInputs",""),("out","/nix/store/1b5frx0a86v8q858i0281bpvfbwb29f8-testbed-wrapped"),("outputs","out"),("passAsFile","text"),("patches",""),("preferLocalBuild","1"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("stdenv","/nix/store/5wly0ig1rwgv67m1dr8gz1655drp3cmn-stdenv-linux"),("strictDeps",""),("system","i686-linux"),("text","#!/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\nset -o errexit\nset -o nounset\nset -o pipefail\n\nset -m  # enable job control: each background job gets its own process group\n\ndeclare -A PIDS=()\ndeclare -A WAIT_PIDS=()\n_FAILED=0\n\nstop_pids() {\n  local -A _remaining=()\n  for PID in \"${!PIDS[@]}\"; do\n    _remaining[$PID]=1\n    kill -INT -- -\"$PID\" 2>/dev/null || true\n    echo \"testbed| PID $PID killed\"\n  done\n  if [ \"${#_remaining[@]}\" -gt 0 ]; then\n    ( sleep 5\n      for _p in \"${!_remaining[@]}\"; do\n        kill -KILL -- -\"$_p\" 2>/dev/null || true\n      done\n    ) &\n    local _alarm=$!\n    while [ \"${#_remaining[@]}\" -gt 0 ]; do\n      local _DONE=\"\"\n      wait -np _DONE \"${!_remaining[@]}\" 2>/dev/null || true\n      [ -n \"${_DONE-}\" ] || break\n      unset \"_remaining[$_DONE]\"\n    done\n    kill -- -\"$_alarm\" 2>/dev/null || true\n    wait \"$_alarm\" 2>/dev/null || true\n  fi\n  PIDS=()\n}\n\ncleanup() {\n  _FAILED=$?\n  echo \"testbed| cleaning up...\"\n  stop_pids\n  exit \"$_FAILED\"\n}\ntrap cleanup EXIT\ntrap 'stop_pids; exit 130' INT TERM\n\nif [ -n \"$(ls -A . 2>/dev/null)\" ]; then\n  echo \"testbed| Error: workDir is not empty: $(pwd)\"\n  exit 1\nfi\n\n_STORE_PATH=\"$(dirname \"$(dirname \"$0\")\")\"\n/nix/store/whfjddffvlqpcba6p53yzx44h72yyp1k-write_run_json/bin/write_run_json \"$_STORE_PATH\"\n\n\n# create nodes\n_PATH=\"\" # clear path\n_PATH=\"/nix/store/7ra6nix64wid0f9rnmh4s0fd3rzrispp-iputils-20250605/bin:$_PATH\"\n_PATH=\"/nix/store/6c0fjwgaxpnnlk5yna14kpan6f0442g3-busybox-mini/bin:$_PATH\"\n_PATH=\"/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin:$_PATH\"\n_PATH=\"/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin:$_PATH\"\n_PATH=\"/nix/store/c9dvy4xm2a4r8fc7pik3871xbh6z2401-iproute2-7.0.0/bin:$_PATH\"\n_PATH=\"/nix/store/gnhnf55iv89m2g9cq5xbgxriwgqarbn0-util-linux-minimal-2.42-bin/bin:$_PATH\"\nmkdir -p 'client'\njail add \\\n  --setenv PATH=$_PATH \\\n  --bind 'client' /pwd \\\n  --chdir /pwd \\\n  client\n_PATH=\"\" # clear path\n_PATH=\"/nix/store/6c0fjwgaxpnnlk5yna14kpan6f0442g3-busybox-mini/bin:$_PATH\"\n_PATH=\"/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin:$_PATH\"\n_PATH=\"/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin:$_PATH\"\n_PATH=\"/nix/store/c9dvy4xm2a4r8fc7pik3871xbh6z2401-iproute2-7.0.0/bin:$_PATH\"\n_PATH=\"/nix/store/gnhnf55iv89m2g9cq5xbgxriwgqarbn0-util-linux-minimal-2.42-bin/bin:$_PATH\"\nmkdir -p 'server'\njail add \\\n  --setenv PATH=$_PATH \\\n  --bind 'server' /pwd \\\n  --chdir /pwd \\\n  server\n\n# sysctl settings\nip netns exec client sysctl -q -w \\\n  net.ipv4.ip_unprivileged_port_start=0 \\\n  net.ipv4.ping_group_range=\"0 0\"\nip netns exec server sysctl -q -w \\\n  net.ipv4.ip_unprivileged_port_start=0 \\\n  net.ipv4.ping_group_range=\"0 0\"\n\n# create veth pairs\nip -n client link add veth0 type veth peer name veth0 netns server\n\n# assign ipv4 addresses\nip -n client -b - <<-'EOF'\n\taddr add 10.0.0.1/24 dev veth0\nEOF\nip -n server -b - <<-'EOF'\n\taddr add 10.0.0.2/24 dev veth0\nEOF\n\n# set interfaces up\nip -n client -b - <<-'EOF'\n\tlink set lo up\n\tlink set veth0 up\nEOF\nip -n server -b - <<-'EOF'\n\tlink set lo up\n\tlink set veth0 up\nEOF\n\n# configure arp\nip -n client -b - <<-'EOF'\n\tlink set veth0 arp off\nEOF\nip -n server -b - <<-'EOF'\n\tlink set veth0 arp off\nEOF\n\n# prefill arp\n_MAC=$(ip netns exec server cat /sys/class/net/veth0/address)\nip -n client neigh add 10.0.0.2 lladdr \"$_MAC\" dev veth0\n_MAC=$(ip netns exec client cat /sys/class/net/veth0/address)\nip -n server neigh add 10.0.0.1 lladdr \"$_MAC\" dev veth0\n\n# node post-setup hooks\nip netns exec client bash -c 'tc qdisc add dev veth0 root netem delay 50ms 15ms loss 10%'\n\nip netns exec server bash -c 'tc qdisc add dev veth0 root netem delay 50ms 15ms loss 10%'\n\n\necho \"testbed| network topology set up\"\n\n# launch background scripts\n(\n  set +m\n  set -o pipefail\n  stdbuf -oL jail enter client \"$(dirname \"$0\")/../nodes/client/scripts/main\" 2>&1 | sed 's/^/client| /'\n) &\necho \"client| main (PID $!) started\"\nPIDS[$!]=1\nWAIT_PIDS[$!]=1\n\n# wait for background processes marked as await\n_FAILED=0\nwhile [ \"${#WAIT_PIDS[@]}\" -gt 0 ]; do\n  _EXIT=0\n  _DONE=\"\"\n  wait -np _DONE \"${!PIDS[@]}\" 2>/dev/null || _EXIT=$?  # watch all PIDs so background exits are collected\n  [ -n \"${_DONE-}\" ] || break\n  echo \"testbed| PID $_DONE exited with $_EXIT\"\n  [ \"$_EXIT\" -eq 0 ] || _FAILED=1\n  unset \"PIDS[$_DONE]\"\n  unset \"WAIT_PIDS[$_DONE]\"\ndone\n[ \"$_FAILED\" -eq 0 ] || exit 1\nstop_pids")])