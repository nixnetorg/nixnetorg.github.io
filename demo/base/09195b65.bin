Derive([("out","/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10","","")],[("/nix/store/3lzzxwghw0y2xqga8l3b6snhmw6mb215-bootstrap-coreutils-5.0.drv",["out"]),("/nix/store/6zkg173cgh1wrcyywcyvsbqdj9mzbvdg-tinycc-musl-unstable-2025-12-03-libs.drv",["out"]),("/nix/store/8kqkwki4v23dns840qq8mw2g0z37fl5g-gawk-5.3.2.drv",["out"]),("/nix/store/bdj46h5g4j93w9a3zh0niqv6xxi3lz77-gnumake-musl-4.4.1.drv",["out"]),("/nix/store/gplz0f8nzzzfxqf5848d8gw8z4id3dq5-gzip-1.2.4.drv",["out"]),("/nix/store/hjk2n7yfq505nnmpbwdj4wzslyrfd17s-gnutar-musl-1.12.drv",["out"]),("/nix/store/pz1z6acpb6x0gyrbysy9rs47vhn4qgzf-mescc-tools-extra-1.9.1.drv",["out"]),("/nix/store/ri59ab1rjfz350rr5b310v4rx3kybljh-gnused-4.2.drv",["out"]),("/nix/store/rnj0rswch7sn9kiqak44kcm3f5i0mq7y-tinycc-musl-unstable-2025-12-03-compiler.drv",["out"]),("/nix/store/swd5ilalrln5hc0vk0d4i3d1566rvnng-bash-2.05b.drv",["out"]),("/nix/store/x2dafg049vyrb1sm6jkydck0b1da2zab-coreutils-9.10.tar.gz.drv",["out"]),("/nix/store/zygspa3c9cxvd4bym18yn6hahpvg48a1-gnugrep-2.4.drv",["out"])],["/nix/store/9hvp9axa7zm732xi5jvg8pckvfk6ixcj-bash-builder.sh"],"i686-linux","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash",["-e","/nix/store/9hvp9axa7zm732xi5jvg8pckvfk6ixcj-bash-builder.sh"],[("PATH","/nix/store/bb1hvg6hg52lcpz7bgyzwbhgaz5dq81l-tinycc-musl-unstable-2025-12-03-compiler/bin:/nix/store/g71r6cvl1sak7a5a1x052nb6b4bql5py-gnumake-musl-4.4.1/bin:/nix/store/cmpkz5yy4rv0c0ny6xrzgckfsdlrllz2-gnused-4.2/bin:/nix/store/8iw88kcninwzwbk02xms6cr1q7yj3fx7-gnugrep-2.4/bin:/nix/store/0xbljs2y42ci87jnnnn9w2iavkrrs2qa-gawk-5.3.2/bin:/nix/store/hyx7fbs539fjk2v0vvac421a4l5vpkpb-gnutar-musl-1.12/bin:/nix/store/1dwbpwfrydg8ayw0bin93gnkgbdxcgi7-gzip-1.2.4/bin:/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin:/nix/store/pp0yi0xvymmfqv3nwbbh0rfglbs5zqih-bootstrap-coreutils-5.0/bin:/nix/store/wrv08hp23d4r3y7im82mz9wagncycpzi-mescc-tools-extra-1.9.1/bin"),("SHELL","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("buildCommand","# Unpack\ntar xzf /nix/store/920ng3f3xpfn9yl0y9kp39685hla7msr-coreutils-9.10.tar.gz\ncd coreutils-9.10\n\n# Configure\nexport CC=\"tcc -B /nix/store/igkpl9ifkvqpxa20i378f300pvpqc5yj-tinycc-musl-unstable-2025-12-03-libs/lib\"\nexport LD=tcc\nexport LDFLAGS=\"-L ./lib\"\nbash ./configure --prefix=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9 --build=i686-unknown-linux-gnu --host=i686-unknown-linux-gnu --disable-dependency-tracking --disable-nls --enable-no-install-program=stdbuf,arch,coreutils,hostname gl_cv_func_getcwd_path_max=\"no, but it is partly working\" gl_cv_have_unlimited_file_name_length=no gl_cv_func_copy_file_range=no gl_cv_onwards_func_copy_file_range=no\n\n# Build\n#\n# Set SUBDIRS=. to avoid cd'ing to gnulib-tests. Those have\n# compilation issues related to pthread and linux/*.h not\n# being available.\nmake -j $NIX_BUILD_CORES AR=\"tcc -ar\" MAKEINFO=\"true\" SUBDIRS=.\n\n# Install\nmake -j $NIX_BUILD_CORES install MAKEINFO=\"true\" SUBDIRS=.\n\n# Remove documentation not needed in the bootstrap chain.\nrm -rf $out/share/info $out/share/man\n"),("builder","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("name","bootstrap-coreutils-musl-9.10"),("out","/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10"),("passAsFile","buildCommand"),("pname","bootstrap-coreutils-musl"),("system","i686-linux"),("version","9.10")])