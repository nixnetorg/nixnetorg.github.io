Derive([("out","/nix/store/qqdvizw5p082r6zwjwwap6dj9vxdcmcb-musl-1.2.6","","")],[("/nix/store/16hpxa0j137szhk78p6w4fxw6irykzjd-bootstrap-coreutils-musl-9.10.drv",["out"]),("/nix/store/4ffpb0qnw94mpb8pc65w31m1gyii6ash-bash-5.3.drv",["out"]),("/nix/store/59pgig863abfc3p6lmz20vh8gjf2nsv1-musl-1.2.6.tar.gz.drv",["out"]),("/nix/store/a0cz6plamv634sihp4drgx4bpxh63jlh-findutils-4.10.0.drv",["out"]),("/nix/store/akjyplvgd19p7sg4xlaqa028fkq2favz-gcc-15.2.0.drv",["out"]),("/nix/store/b9iqif0kvs9ijbn9d5qwcmzza2idg463-binutils-2.46.0.drv",["out"]),("/nix/store/bdj46h5g4j93w9a3zh0niqv6xxi3lz77-gnumake-musl-4.4.1.drv",["out"]),("/nix/store/gplz0f8nzzzfxqf5848d8gw8z4id3dq5-gzip-1.2.4.drv",["out"]),("/nix/store/hp37ysjg2663kmdmvi945qqlrkiw3vmr-gnutar-1.12.drv",["out"]),("/nix/store/qczxhh9ll32vr9009apksr8xypc6qyr3-linux-headers-6.5.6.drv",["out"]),("/nix/store/ri59ab1rjfz350rr5b310v4rx3kybljh-gnused-4.2.drv",["out"]),("/nix/store/zygspa3c9cxvd4bym18yn6hahpvg48a1-gnugrep-2.4.drv",["out"])],["/nix/store/70acbfgbz5cxsx4sqzcnj8qaqhb4i9ay-bash-builder.sh"],"i686-linux","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash",["-e","/nix/store/70acbfgbz5cxsx4sqzcnj8qaqhb4i9ay-bash-builder.sh"],[("PATH","/nix/store/1sn54z1pbi02669jkbl09q11vn2b5zkv-gcc-15.2.0/bin:/nix/store/vsgslsdli52psy9c7jy5lpx2lz2gsxxl-binutils-2.46.0/bin:/nix/store/8f4w9gcmf39dr93f6h70nyfkhk6basdn-findutils-4.10.0/bin:/nix/store/g71r6cvl1sak7a5a1x052nb6b4bql5py-gnumake-musl-4.4.1/bin:/nix/store/cmpkz5yy4rv0c0ny6xrzgckfsdlrllz2-gnused-4.2/bin:/nix/store/8iw88kcninwzwbk02xms6cr1q7yj3fx7-gnugrep-2.4/bin:/nix/store/xjw5xk5hidsqrg9ans9csfg46rp67dz6-gnutar-1.12/bin:/nix/store/1dwbpwfrydg8ayw0bin93gnkgbdxcgi7-gzip-1.2.4/bin:/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin:/nix/store/24jjs5dq88rlpw9wx4h5dzlx8wsqp72f-bootstrap-coreutils-musl-9.10/bin"),("SHELL","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("buildCommand","# Unpack\ntar xzf /nix/store/1j3vmqzmlbx2j10q0j061fqychxd7q4i-musl-1.2.6.tar.gz\ncd musl-1.2.6\n\n# Patch\n# https://github.com/ZilchOS/bootstrap-from-tcc/blob/2e0c68c36b3437386f786d619bc9a16177f2e149/using-nix/2a3-intermediate-musl.nix\nsed -i 's|/bin/sh|/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash|' \\\n  tools/*.sh\n# patch popen/system to search in PATH instead of hardcoding /bin/sh\nsed -i 's|posix_spawn(&pid, \"/bin/sh\",|posix_spawnp(\\&pid, \"sh\",|' \\\n  src/stdio/popen.c src/process/system.c\nsed -i 's|execl(\"/bin/sh\", \"sh\", \"-c\",|execlp(\"sh\", \"-c\",|'\\\n  src/misc/wordexp.c\n\n# Configure\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --syslibdir=$out/lib \\\n  --enable-wrapper\n\n# Build\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install\nsed -i 's|/bin/sh|/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash|' $out/bin/*\nln -s ../lib/libc.so $out/bin/ldd\nln -s $(ls -d /nix/store/f86v669fbqirr750qvdz2npczflw0gz4-linux-headers-6.5.6/include/* | grep -v scsi\\$) $out/include/\n\n# Strip\n# Ignore failures, because strip may fail on non-elf files.\nfind $out/{bin,lib} -type f -exec strip --strip-debug {} + || true\n"),("builder","/nix/store/5jn8zkk3c87gx6nr9lbrvxpi8a6n9p4n-bash-5.3/bin/bash"),("name","musl-1.2.6"),("out","/nix/store/qqdvizw5p082r6zwjwwap6dj9vxdcmcb-musl-1.2.6"),("passAsFile","buildCommand"),("pname","musl"),("system","i686-linux"),("version","1.2.6")])