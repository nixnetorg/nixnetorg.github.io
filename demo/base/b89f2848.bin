ion.c\nCC -c xmalloc.c\nCC -c error.c\n\n# Link\nCC -o patch addext.o argmatch.o backupfile.o basename.o dirname.o getopt.o getopt1.o inp.o maketime.o partime.o patch.o pch.o quote.o quotearg.o quotesys.o util.o version.o xmalloc.o error.o\n\n# Check\n./patch --version\n\n# Install\nmkdir -p ${out}/bin\ncp ./patch ${out}/bin\nchmod 555 ${out}/bin/patch\n")])