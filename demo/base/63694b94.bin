s","/nix/store/4jm81bjhvq68syfb52p51rffm8c9kv1b-libpipeline-1.5.8 /nix/store/6k4zi2xf32j7b0f1c94hqjc40ib5vl1z-gdbm-1.26-dev /nix/store/4i4c06sgndc0nvy9h8ha6cvgdnywrgmd-groff-1.24.1 /nix/store/cbl8cichxkvnpw9ba8ns9353l7m4pcq8-glibc-iconv-2.42"),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("cmakeFlags",""),("configureFlags","--disable-setuid --disable-cache-owner --localstatedir=/var --with-config-file=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9/etc/man_db.conf --with-systemdtmpfilesdir=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9/lib/tmpfiles.d --with-systemdsystemunitdir=/1rz4g4znpzjwh1xymhjpm42vipw92pr73vdgl6xs1hycac8kf2n9/lib/systemd/system --with-pager=less --with-col=/nix/store/gnhnf55iv89m2g9cq5xbgxriwgqarbn0-util-linux-minimal-2.42-bin/bin/col"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("disallowedReferences",""),("doCheck","1"),("doInstallCheck",""),("doc","/nix/store/qm03jjs5n50iy1llh904xi72c419h3zh-man-db-2.13.1-doc"),("enableParallelBuilding","1"),("enableParallelChecking","1"),("enableParallelInstalling","1"),("mesonFlags",""),("name","man-db-2.13.1"),("nativeBuildInputs","/nix/store/7shwrk6l6kg7lygw7zarha7j640j0rrf-autoconf-2.73 /nix/store/b0zk4lydx3fj7nk6bsv83vsw16q5yji0-automake-1.18.1 /nix/store/zdxr0nbhv8nyrmpw3cw16ch4hcclcsj0-flex-2.6.4 /nix/store/rvfxk3i6lznn12l2k04dgzall45zh6gh-gettext-1.0 /nix/store/4i4c06sgndc0nvy9h8ha6cvgdnywrgmd-groff-1.24.1 /nix/store/y0n6184z1cxyf87bsn1jnhbvcj3jv477-libtool-2.5.4 /nix/store/wajh14qai1lyy314blmzk3lkyk230563-make-shell-wrapper-hook /nix/store/x17mq9srwk8lxv0797r39d4k3zbrzz0n-pkg-config-wrapper-0.29.2 /nix/store/28r04jfalh92zl12k0hbwi900lrvkryz-zstd-1.5.7-dev /nix/store/cbl8cichxkvnpw9ba8ns9353l7m4pcq8-glibc-iconv-2.42"),("out","/nix/store/vv3kmqcr3da92cpar9dq7ipnfp6w9l6k-man-db-2.13.1"),("outputMan","out"),("outputs","out doc"),("patches","/nix/store/p4m9shlpsqrvir464livcdni0y32ah3f-systemwide-man-db-conf.patch"),("pname","man-db"),("postInstall","# apropos/whatis uses program name to decide whether to act like apropos or whatis\n# (multi-call binary). `apropos` is actually just a symlink to whatis. So we need to\n# make sure that we don't wrap symlinks (since that changes argv[0] to the -wrapped name)\nfind \"$out/bin\" -type f | while read file; do\n  wrapProgram \"$file\" \\\n    --prefix PATH : \"/nix/store/4i4c06sgndc0nvy9h8ha6cvgdnywrgmd-groff-1.24.1/bin:/nix/store/hd3r6w0sb5cc8yz33a3s4yyggp55ykh0-gzip-1.14/bin:/nix/store/2322q8fawgiiy0fikwv5qrn9kjx3i2m9-zstd-1.5.7-bin/bin\"\ndone\n"),("postPatch","# Remove all mandatory manpaths. Nixpkgs makes no requirements on\n# these directories existing.\nsed -i 's/^MANDATORY_MANPATH/# &/' src/man_db.conf.in\n\n# Add Nix-related manpaths\necho \"MANPATH_MAP\t/nix/var/nix/profiles/default/bin\t/nix/var/nix/profiles/default/share/man\" >> src/man_db.conf.in\n\n# Add mandb locations for the above\necho \"MANDB_MAP\t/nix/var/nix/profiles/default/share/man\t/var/cache/man/nixpkgs\" >> src/man_db.conf.in\n"),("preConfigure","./bootstrap --no-git --gnulib-srcdir=/nix/store/nbq2iijrl36xhyqwwq057czzmw5lv985-gnulib-20241001 --gen\nconfigureFlagsArray+=(\"--with-sections=1 n l 8 3 0 2 5 4 9 6 7\")\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("src","/nix/store/6kz444k9yjlacfhrbw84qrbw1mk7vjgw-source"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","2.13.1")])