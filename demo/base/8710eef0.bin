Derive([("doc","/nix/store/500fr4zzp7rf5ylh043q6kl5x9b86k0w-gettext-1.0-doc","",""),("info","/nix/store/5cw321fw61dl7x5q4q5j3ksn7w990ppv-gettext-1.0-info","",""),("man","/nix/store/ks2cr9rs1npshjnpl7ak77khxx2j9554-gettext-1.0-man","",""),("out","/nix/store/lismjp1qvhxn0bccl4gbwbpns4vyragh-gettext-1.0","","")],[("/nix/store/dv73mfs0lnij5wcxxkr753c2kfdwql35-update-autotools-gnu-config-scripts-hook.drv",["out"]),("/nix/store/i81n3wi4pdxwhcsi7n47fqidmvaldm00-bootstrap-stage1-stdenv-linux.drv",["out"]),("/nix/store/lgdzyl3iw2qs3ghw13bfr854v654y0yj-bash-5.3p9.drv",["dev"]),("/nix/store/ng1x07kxip0j8q8ww6jxb6vv4sd4hm26-bash-static-5.3.drv",["out"]),("/nix/store/zdbga6f8g5jysvhngmnjlwmj674bzds2-gettext-1.0.tar.gz.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash","/nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"],"i686-linux","/nix/store/f2j5nvp6hs78nmcf4sf74nyhx1fzxnh4-bash-static-5.3/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__structuredAttrs",""),("am_cv_func_iconv_works","yes"),("buildInputs","/nix/store/6jz0q0vdnjdhg2f3fr8vdrz3rbq8npn8-bash-5.3p9-dev"),("builder","/nix/store/f2j5nvp6hs78nmcf4sf74nyhx1fzxnh4-bash-static-5.3/bin/bash"),("cmakeFlags",""),("configureFlags","--disable-csharp"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("doCheck",""),("doInstallCheck",""),("doc","/nix/store/500fr4zzp7rf5ylh043q6kl5x9b86k0w-gettext-1.0-doc"),("enableParallelBuilding","1"),("enableParallelChecking",""),("enableParallelInstalling","1"),("gettextNeedsLdflags",""),("info","/nix/store/5cw321fw61dl7x5q4q5j3ksn7w990ppv-gettext-1.0-info"),("man","/nix/store/ks2cr9rs1npshjnpl7ak77khxx2j9554-gettext-1.0-man"),("mesonFlags",""),("name","gettext-1.0"),("nativeBuildInputs","/nix/store/kp5hi8lnxz7scrp4ca14s7000rgbvyjv-update-autotools-gnu-config-scripts-hook"),("out","/nix/store/lismjp1qvhxn0bccl4gbwbpns4vyragh-gettext-1.0"),("outputs","out man doc info"),("patches","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff /nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"),("pname","gettext"),("postPatch","# Older versions of gettext come with a copy of `extern-inline.m4` that is not compatible with clang 18.\n# When a project uses gettext + autoreconfPhase, autoreconfPhase will invoke `autopoint -f`, which will\n# replace whatever (probably compatible) version of `extern-inline.m4` with one that probalby won’t work\n# because `autopoint` will copy the autoconf macros from the project’s required version of gettext.\n# Fixing this requires replacing all the older copies of the problematic file with a new one.\n#\n# This is ugly, but it avoids requiring workarounds in every package using gettext and autoreconfPhase.\ndeclare -a oldFiles=($(tar tf gettext-tools/autotools/archive.dir.tar | grep '^gettext-0\\.[19].*/extern-inline.m4'))\noldFilesDir=$(mktemp -d)\nfor oldFile in \"${oldFiles[@]}\"; do\n  mkdir -p \"$oldFilesDir/$(dirname \"$oldFile\")\"\n  cp -a gettext-tools/gnulib-m4/extern-inline.m4 \"$oldFilesDir/$oldFile\"\ndone\ntar uf gettext-tools/autotools/archive.dir.tar --owner=0 --group=0 --numeric-owner -C \"$oldFilesDir\" \"${oldFiles[@]}\"\n\nsubstituteAllInPlace gettext-runtime/src/gettext.sh.in\nsubstituteInPlace gettext-tools/projects/KDE/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/projects/GNOME/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/src/project-id --replace \"/bin/pwd\" pwd\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("setupHooks","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash /nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh"),("src","/nix/store/n4lwy41bnpq1fsqsrf5fac3m7vmhk6sr-gettext-1.0.tar.gz"),("stdenv","/nix/store/naqiwfii58hm3q65vxcnpp9z33flbfwn-bootstrap-stage1-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","1.0")])