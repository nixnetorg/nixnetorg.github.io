GTK_A11Y   DEFAULT="none"
GTK_PATH   DEFAULT="@{HOME}/.nix-profile/lib/gtk-2.0:@{HOME}/.nix-profile/lib/gtk-3.0:@{HOME}/.nix-profile/lib/gtk-4.0:${XDG_STATE_HOME}/nix/profile/lib/gtk-2.0:${XDG_STATE_HOME}/nix/profile/lib/gtk-3.0:${XDG_STATE_HOME}/nix/profile/lib/gtk-4.0:@{HOME}/.local/state/nix/profile/lib/gtk-2.0:@{HOME}/.local/state/nix/profile/lib/gtk-3.0:@{HOME}/.local/state/nix/profile/lib/gtk-4.0:/etc/profiles/per-user/@{PAM_USER}/lib/gtk-2.0:/etc/profiles/per-user/@{PAM_USER}/lib/gtk-3.0:/etc/profiles/per-user/@{PAM_USER}/lib/gtk-4.0:/nix/var/nix/profiles/default/lib/gtk-2.0:/nix/var/nix/profiles/default/lib/gtk-3.0:/nix/var/nix/profiles/default/lib/gtk-4.0:/run/current-system/sw/lib/gtk-2.0:/run/current-system/sw/lib/gtk-3.0:/run/current-system/sw/lib/gtk-4.0"
INFOPATH   DEFAULT="@{HOME}/.nix-profile/info:@{HOME}/.nix-profile/share/info:${XDG_STATE_HOME}/nix/profile/info:${XDG_STATE_HOME}/nix/profile/share/info:@{HOME}/.local/state/nix/profile/info:@{HOME}/.local/state/nix/profile/share/info:/etc/profiles/per-user/@{PAM_USER}/info:/etc/profiles/per-user/@{PAM_USER}/share/info:/nix/var/nix/profiles/default/info:/nix/var/nix/profiles/default/share/info:/run/current-system/sw/info:/run/current-system/sw/share/info"
LANG   DEFAULT="C.UTF-8"
LIBEXEC_PATH   DEFAULT="@{HOME}/.nix-profile/libexec:${XDG_STATE_HOME}/nix/profile/libexec:@{HOME}/.local/state/nix/profile/libexec:/etc/profiles/per-user/@{PAM_USER}/libexec:/nix/var/nix/profiles/default/libexec:/run/current-system/sw/libexec"
LOCALE_ARCHIVE   DEFAULT="/run/current-system/sw/lib/locale/locale-archive"
NIX_PATH   DEFAULT=""
NO_AT_BRIDGE   DEFAULT="1"
PATH   DEFAULT="/run/wrappers/bin:@{HOME}/.nix-profile/bin:${XDG_STATE_HOME}/nix/profile/bin:@{HOME}/.local/state/nix/profile/bin:/etc/profiles/per-user/@{PAM_USER}/bin:/nix/var/nix/profiles/default/bin:/run/current-system/sw/bin"
QTWEBKIT_PLUGIN_PATH   DEFAULT="@{HOME}/.nix-profile/lib/mozilla/plugins/:${XDG_STATE_HOME}/nix/profile/lib/mozilla/plugins/:@{HOME}/.local/state/nix/profile/lib/mozilla/plugins/:/etc/profiles/per-user/@{PAM_USER}/lib/mozilla/plugins/:/nix/var/nix/profiles/default/lib/mozilla/plugins/:/run/current-system/sw/lib/mozilla/plugins/"
TERMINFO_DIRS   DEFAULT="@{HOME}/.nix-profile/share/terminfo:${XDG_STATE_HOME}/nix/profile/share/terminfo:@{HOME}/.local/state/nix/profile/share/terminfo:/etc/profiles/per-user/@{PAM_USER}/share/terminfo:/nix/var/nix/profiles/default/share/terminfo:/run/current-system/sw/share/terminfo"
TZDIR   DEFAULT="/etc/zoneinfo"
XDG_CONFIG_DIRS   DEFAULT="/etc/xdg:@{HOME}/.nix-profile/etc/xdg:${XDG_STATE_HOME}/nix/profile/etc/xdg:@{HOME}/.local/state/nix/profile/etc/xdg:/etc/profiles/per-user/@{PAM_USER}/etc/xdg:/nix/var/nix/profiles/default/etc/xdg:/run/current-system/sw/etc/xdg"
XDG_DATA_DIRS   DEFAULT="@{HOME}/.nix-profile/share:${XDG_STATE_HOME}/nix/profile/share:@{HOME}/.local/state/nix/profile/share:/etc/profiles/per-user/@{PAM_USER}/share:/nix/var/nix/profiles/default/share:/run/current-system/sw/share"
