 clang $out/bin/cc\n  export named_cc=clang\n  export named_cxx=clang++\nelif [ -e $ccPath/arocc ]; then\n  wrap arocc $wrapper $ccPath/arocc\n  ln -s arocc $out/bin/cc\n  export named_cc=arocc\nfi\n\nif [ -e $ccPath/g++ ]; then\n  wrap g++ $wrapper $ccPath/g++\n  ln -s g++ $out/bin/c++\nelif [ -e $ccPath/clang++ ]; then\n  wrap clang++ $wrapper $ccPath/clang++\n  ln -s clang++ $out/bin/c++\nfi\n\nif [ -e $ccPath/cpp ]; then\n  wrap cpp $wrapper $ccPath/cpp\nelif [ -e $ccPath/cpp ]; then\n  wrap cpp $wrapper $ccPath/cpp\nfi\n"),("isArocc",""),("isClang",""),("libc_bin","/nix/store/4rdi22m1h50r85bspswq96rpk4rm5p5j-bootstrap-stage0-glibc-minimal-bootstrap"),("libc_dev","/nix/store/4rdi22m1h50r85bspswq96rpk4rm5p5j-bootstrap-stage0-glibc-minimal-bootstrap"),("libc_lib","/nix/store/4rdi22m1h50r85bspswq96rpk4rm5p5j-bootstrap-stage0-glibc-minimal-bootstrap"),("man","/nix/store/kn5rfpsg2517k2pch0b5vb4cs0r038yv-bootstrap-stage2-gcc-wrapper-15.2.0-man"),("mesonFlags",""),("mktemp","/nix/store/f9r12f6n8hm256z2ml3xn9rg39a5cbp1-coreutils-static-9.10/bin/mktemp"),("name","bootstrap-stage2-gcc-wrapper-15.2.0"),("nativeBuildInputs",""),("out","/nix/store/msrkvv925gd0k6ps0asp9mrnpxwpxrmi-bootstrap-stage2-gcc-wrapper-15.2.0"),("outputs","out man info"),("patches",""),("pname","bootstrap-stage2-gcc-wrapper"),("postFixup","touch \"$out/nix-support/cc-cflags\"\ntouch \"$out/nix-support/cc-ldflags\"\nif [[ -f \"$bintools/nix-support/dynamic-linker\" ]]; then\n  ln -s \"$bintools/nix-support/dynamic-linker\" \"$out/nix-support\"\nfi\nif [[ -f \"$bintools/nix-support/dynamic-linker-m32\" ]]; then\n  ln -s \"$bintools/nix-support/dynamic-linker-m32\" \"$out/nix-support\"\nfi\necho \"-L/nix/store/d6znb568ihs3c3xgf2b04zk26jnyyrdk-xgcc-15.2.0/lib/gcc/i686-unknown-linux-gnu/15.2.0\" >> $out/nix-support/cc-ldflags\necho \"-L/nix/store/yx5rrq89lhshvpfk46nr070cwfvbidbb-xgcc-15.2.0-lib/lib\" >> $out/nix-support/cc-ldflags\ntouch \"$out/nix-support/libc-cflags\"\ntouch \"$out/nix-support/libc-ldflag