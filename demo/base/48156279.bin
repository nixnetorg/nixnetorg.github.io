Derive([("out","/nix/store/rln0cl48nb77xf4r47m75658mrp5ibf1-jail_setup","","")],[("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/i2iy5vhwb7g1pv5svyyzhpcpagwvwwdv-stdenv-linux.drv",["out"]),("/nix/store/nli0vg7g3bnbxl1ybjas59bwswbdyg51-util-linux-minimal-2.42.drv",["bin"]),("/nix/store/rrwx4izf1zb8k7394wkhk82xcy17g33q-coreutils-9.11.drv",["out"]),("/nix/store/vj2j7dn6fhmsbcbvk1920z9lk7sbmchh-busybox-mini.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("NIX_MAIN_PROGRAM","jail_setup"),("__structuredAttrs",""),("allowSubstitutes","1"),("buildCommand","target=$out$destination\nmkdir -p \"$(dirname \"$target\")\"\n\nif [ -e \"$textPath\" ]; then\n  mv \"$textPath\" \"$target\"\nelse\n  printf \"%s\" \"$text\" > \"$target\"\nfi\n\nif [ -n \"$executable\" ]; then\n  chmod +x \"$target\"\nfi\n\neval \"$checkPhase\"\n"),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("checkPhase","runHook preCheck\n/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash -n -O extglob \"$target\"\n\nrunHook postCheck\n"),("cmakeFlags",""),("configureFlags",""),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("destination","/bin/jail_setup"),("doCheck",""),("doInstallCheck",""),("executable","1"),("mesonFlags",""),("name","jail_setup"),("nativeBuildInputs",""),("out","/nix/store/rln0cl48nb77xf4r47m75658mrp5ibf1-jail_setup"),("outputs","out"),("passAsFile","text"),("patches",""),("preferLocalBuild",""),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("stdenv","/nix/store/5wly0ig1rwgv67m1dr8gz1655drp3cmn-stdenv-linux"),("strictDeps",""),("system","i686-linux"),("text","#!/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\nset -o errexit\nset -o nounset\nset -o pipefail\n\nexport PATH=\"/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin:/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin:/nix/store/gnhnf55iv89m2g9cq5xbgxriwgqarbn0-util-linux-minimal-2.42-bin/bin:/nix/store/6c0fjwgaxpnnlk5yna14kpan6f0442g3-busybox-mini/bin:$PATH\"\n\n#!/usr/bin/env bash\n# Called by jail to set up the sandbox filesystem inside a new mount namespace.\n# Expects exported variables: NAME, CHDIR, WAYLAND, HAS_USERNS, JAIL_BINDS, JAIL_SETENV.\nset -euo pipefail\nNEW_ROOT=\"$(mktemp -d)\"\nmount -t tmpfs tmpfs \"$NEW_ROOT\"\nmkdir -p \\\n  \"$NEW_ROOT/old_root\" \\\n  \"$NEW_ROOT/bin\" \\\n  \"$NEW_ROOT/var/run/netns\" \\\n  \"$NEW_ROOT/nix/store\" \\\n  \"$NEW_ROOT/proc\" \\\n  \"$NEW_ROOT/sys\" \\\n  \"$NEW_ROOT/tmp\" \\\n  \"$NEW_ROOT/dev/pts\" \\\n  \"$NEW_ROOT/dev/shm\" \\\n  \"$NEW_ROOT/root\" \\\n  \"$NEW_ROOT/etc\"\nchmod 1777 \"$NEW_ROOT/dev/shm\"\nln -s \"$(command -v bash)\" \"$NEW_ROOT/bin/sh\"\nln -sf /dev/pts/ptmx \"$NEW_ROOT/dev/ptmx\"\nln -s /proc/self/fd \"$NEW_ROOT/dev/fd\"\nln -s /proc/self/fd/0 \"$NEW_ROOT/dev/stdin\"\nln -s /proc/self/fd/1 \"$NEW_ROOT/dev/stdout\"\nln -s /proc/self/fd/2 \"$NEW_ROOT/dev/stderr\"\ntouch \\\n  \"$NEW_ROOT/dev/null\" \\\n  \"$NEW_ROOT/dev/zero\" \\\n  \"$NEW_ROOT/dev/urandom\" \\\n  \"$NEW_ROOT/dev/random\"\nmount -t devpts devpts \"$NEW_ROOT/dev/pts\" -o newinstance,ptmxmode=0666\nmount --bind /dev/null \"$NEW_ROOT/dev/null\"\nmount --bind /dev/zero \"$NEW_ROOT/dev/zero\"\nmount --bind /dev/urandom \"$NEW_ROOT/dev/urandom\"\nmount --bind /dev/random \"$NEW_ROOT/dev/random\"\nmount --bind /nix/store \"$NEW_ROOT/nix/store\"\nmount --rbind /sys \"$NEW_ROOT/sys\" # required otherwise \"ip netns exec\" fails inside\nprintf \"root:x:0:0:root:/root:/bin/sh\\n\" > \"$NEW_ROOT/etc/passwd\"\nprintf \"nobody:x:65534:65534:nobody:/var/empty:/bin/sh\\n\" >> \"$NEW_ROOT/etc/passwd\"\nprintf \"root:x:0:\\n\" > \"$NEW_ROOT/etc/group\"\nprintf \"nobody:x:65534:\\n\" >> \"$NEW_ROOT/etc/group\"\nprintf \"nogroup:x:65534:\\n\" >> \"$NEW_ROOT/etc/group\"\nprintf \"%s\\n\" \"$NAME\" > \"$NEW_ROOT/etc/hostname\"\nwhile IFS= read -r _entry; do\n  [ -z \"$_entry\" ] && continue\n  _mode=\"${_entry%%:*}\"; _rest=\"${_entry#*:}\"\n  _src=\"${_rest%%:*}\"; _dst=\"${_rest#*:}\"\n  if [ -d \"$_src\" ]; then\n    mkdir -p \"$NEW_ROOT$_dst\"\n  else\n    mkdir -p \"$NEW_ROOT$(dirname \"$_dst\")\"\n    touch \"$NEW_ROOT$_dst\"\n  fi\n  mount --bind \"$_src\" \"$NEW_ROOT$_dst\"\n  if [ \"$_mode\" = ro ]; then\n    mount -o remount,ro,bind \"$NEW_ROOT$_dst\"\n  fi\ndone <<< \"$JAIL_BINDS\"\nif [ \"$WAYLAND\" = true ]; then\n  mkdir -p \"$NEW_ROOT/run/user/0\"\n  touch \"$NEW_ROOT/run/user/0/wayland-0\"\n  mount --rbind \"$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY\" \"$NEW_ROOT/run/user/0/wayland-0\"\n  if [ -e /dev/dri ]; then\n    mkdir -p \"$NEW_ROOT/dev/dri\"\n    mount --bind /dev/dri \"$NEW_ROOT/dev/dri\"\n  fi\n  if [ -d /run/opengl-driver ]; then\n    mkdir -p \"$NEW_ROOT/run/opengl-driver\"\n    mount --bind /run/opengl-driver \"$NEW_ROOT/run/opengl-driver\"\n  fi\nfi\n_ENV=(\n  \"PWD=$CHDIR\"\n  \"HOME=/root\"\n  \"USER=root\"\n  \"TERM=${TERM:-}\"\n)\nif [ \"$WAYLAND\" = true ]; then\n  _ENV+=(\n    \"XDG_RUNTIME_DIR=/run/user/0\"\n    \"WAYLAND_DISPLAY=wayland-0\"\n    \"DISPLAY=${DISPLAY:-}\"\n    \"NIXOS_OZONE_WL=${NIXOS_OZONE_WL:-}\"\n    \"XDG_SESSION_TYPE=${XDG_SESSION_TYPE:-}\"\n  )\nfi\nwhile IFS= read -r _e; do\n  [ -n \"$_e\" ] && _ENV+=(\"$_e\")\ndone <<< \"$JAIL_SETENV\"\nmkdir -p \"$NEW_ROOT$CHDIR\"\nmount -t proc proc \"$NEW_ROOT/proc\"\nif [ -n \"$NAME\" ]; then\n  printf \"%s\\n\" \"${_ENV[@]}\" > \"/run/jail/$NAME/env\"\n  # write outer init PID of jail to fifo before pivot_root\n  # use read builtin to not fork \n  read -r _outer_pid _ < /proc/self/stat\n  printf \"%s\\n\" \"$_outer_pid\" > \"/run/jail/$NAME/.pid_fifo\"\nfi\npivot_root \"$NEW_ROOT\" \"$NEW_ROOT/old_root\"\nif [ \"$HAS_USERNS\" -ne 0 ]; then\n  mount -t sysfs sysfs /sys # required for \"ip netns exec\" inside a user namespace\nfi\ncd /\numount -l /old_root\nrmdir /old_root\nif [ -n \"$NAME\" ]; then\n  exec env -i --chdir \"$CHDIR\" \"${_ENV[@]}\" \"$@\"  # named jail: init handles signals itself\nfi\n# Run the command via setsid so a terminal SIGINT can't reach it directly; we\n# forward signals to it as SIGTERM instead (a foreground job bypasses an INT trap\n# but runs a TERM trap). Traps are installed before the child starts so an early\n# signal can't tear the namespace down via the default handler.\n_SIGNAL=0\n# kill -- -1 signals every process in this pid namespace except us (PID 1).\ntrap '_SIGNAL=130; kill -s TERM -- -1 2>/dev/null' INT\ntrap '_SIGNAL=143; kill -s TERM -- -1 2>/dev/null' TERM\nsetsid env -i --chdir \"$CHDIR\" \"${_ENV[@]}\" \"$@\" <&0 &\nPID=$!\n# '|| EXIT_CODE=$?' so set -e doesn't exit on the signal-killed child before the\n# grace block below runs.\nEXIT_CODE=0\nwait \"$PID\" 2>/dev/null || EXIT_CODE=$?\nif [ \"$_SIGNAL\" -ne 0 ]; then\n  trap '' INT TERM  # ignore duplicate signals while cleanup runs\n  # Let cleanup traps finish before we exit (and the kernel SIGKILLs the rest):\n  # poll until the process table goes quiet, bounded by a deadline so a stuck\n  # process can't hang teardown. We poll instead of wait because the command's\n  # descendants aren't all our children, and named-jail inits stay alive by design.\n  _deadline=$((SECONDS + 5)); _prev=-1; _settle=0\n  while (( SECONDS < _deadline )); do\n    _procs=(/proc/[0-9]*); _cur=${#_procs[@]}\n    (( _cur == _prev )) && _settle=$((_settle + 1)) || _settle=0\n    (( _settle >= 4 )) && break\n    _prev=$_cur; sleep 0.05\n  done\n  exit \"$_SIGNAL\"\nfi\ntrap - INT TERM\nexit \"$EXIT_CODE\"\n\n")])