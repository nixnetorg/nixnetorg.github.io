Derive([("doc","/nix/store/anvqyg15bbln7r8y8511y5ff87lr3m9n-gettext-1.0-doc","",""),("info","/nix/store/cd77bgamb32z9zdcmwh2p0a7h2pzgcp5-gettext-1.0-info","",""),("man","/nix/store/q5ccn0v3is54i7c2f28n7g20a9ip0vw8-gettext-1.0-man","",""),("out","/nix/store/359xv4243vd71zinm4v17bag7zk4dm60-gettext-1.0","","")],[("/nix/store/gvk6z998xgp9kdqlg2p7wy4w5xszsmym-bootstrap-stage3-stdenv-linux.drv",["out"]),("/nix/store/hk279rfj8grlv77lx7wxjqi9abfb0zsg-bash-5.3p9.drv",["dev"]),("/nix/store/hwv9q4gnwqlbk8f1477xxgfwshsq9rcz-update-autotools-gnu-config-scripts-hook.drv",["out"]),("/nix/store/ng1x07kxip0j8q8ww6jxb6vv4sd4hm26-bash-static-5.3.drv",["out"]),("/nix/store/zdbga6f8g5jysvhngmnjlwmj674bzds2-gettext-1.0.tar.gz.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash","/nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"],"i686-linux","/nix/store/f2j5nvp6hs78nmcf4sf74nyhx1fzxnh4-bash-static-5.3/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("__structuredAttrs",""),("buildInputs","/nix/store/9j5x0j1v67f0h5hbgdmgh552whwm0kqd-bash-5.3p9-dev"),("builder","/nix/store/f2j5nvp6hs78nmcf4sf74nyhx1fzxnh4-bash-static-5.3/bin/bash"),("cmakeFlags",""),("configureFlags","--disable-csharp"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("doCheck",""),("doInstallCheck",""),("doc","/nix/store/anvqyg15bbln7r8y8511y5ff87lr3m9n-gettext-1.0-doc"),("enableParallelBuilding","1"),("enableParallelChecking",""),("enableParallelInstalling","1"),("gettextNeedsLdflags",""),("info","/nix/store/cd77bgamb32z9zdcmwh2p0a7h2pzgcp5-gettext-1.0-info"),("man","/nix/store/q5ccn0v3is54i7c2f28n7g20a9ip0vw8-gettext-1.0-man"),("mesonFlags",""),("name","gettext-1.0"),("nativeBuildInputs","/nix/store/8iva45zlhgdiik6kfd2p1y2s9qr2x9i1-update-autotools-gnu-config-scripts-hook"),("out","/nix/store/359xv4243vd71zinm4v17bag7zk4dm60-gettext-1.0"),("outputs","out man doc info"),("patches","/nix/store/p2fp6i7hjx9af1wbwr32k217wp2dxmiw-absolute-paths.diff /nix/store/yqwx9yln5i68nw61mmp9gz066yz3ri99-0001-msginit-Do-not-use-POT-Creation-Date.patch"),("pname","gettext"),("postPatch","# Older versions of gettext come with a copy of `extern-inline.m4` that is not compatible with clang 18.\n# When a project uses gettext + autoreconfPhase, autoreconfPhase will invoke `autopoint -f`, which will\n# replace whatever (probably compatible) version of `extern-inline.m4` with one that probalby won’t work\n# because `autopoint` will copy the autoconf macros from the project’s required version of gettext.\n# Fixing this requires replacing all the older copies of the problematic file with a new one.\n#\n# This is ugly, but it avoids requiring workarounds in every package using gettext and autoreconfPhase.\ndeclare -a oldFiles=($(tar tf gettext-tools/autotools/archive.dir.tar | grep '^gettext-0\\.[19].*/extern-inline.m4'))\noldFilesDir=$(mktemp -d)\nfor oldFile in \"${oldFiles[@]}\"; do\n  mkdir -p \"$oldFilesDir/$(dirname \"$oldFile\")\"\n  cp -a gettext-tools/gnulib-m4/extern-inline.m4 \"$oldFilesDir/$oldFile\"\ndone\ntar uf gettext-tools/autotools/archive.dir.tar --owner=0 --group=0 --numeric-owner -C \"$oldFilesDir\" \"${oldFiles[@]}\"\n\nsubstituteAllInPlace gettext-runtime/src/gettext.sh.in\nsubstituteInPlace gettext-tools/projects/KDE/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/projects/GNOME/trigger --replace \"/bin/pwd\" pwd\nsubstituteInPlace gettext-tools/src/project-id --replace \"/bin/pwd\" pwd\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("setupHooks","/nix/store/v9034cqc4h5bm10z4vz3n1q2n55grv5y-role.bash /nix/store/ny42y6hs4p294rvnrwbmrpwzqghw2816-gettext-setup-hook.sh"),("src","/nix/store/n4lwy41bnpq1fsqsrf5fac3m7vmhk6sr-gettext-1.0.tar.gz"),("stdenv","/nix/store/i8vki1mc47bjynblwksxn8f623s0mkrv-bootstrap-stage3-stdenv-linux"),("strictDeps","1"),("system","i686-linux"),("version","1.0")])