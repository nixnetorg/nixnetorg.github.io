h8hbdn4g3cym0l452bzl-no-stamp.patch\n\n# Configure\nexport CC=\"tcc -B /nix/store/0fks57d0gyhk6g3niadg55mrxhgfslsq-tinycc-mes-libs-unstable-2025-12-03/lib\"\nexport ac_cv_func_getpgrp_void=yes\nexport ac_cv_func_tzset=yes\nbash ./configure \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --disable-dependency-tracking \\\n  --disable-nls \\\n  --prefix=$out\n\n# Build\n# NOTE: parallel build (-j) breaks gawk autoconf'd Makefile under tcc-mes; keep serial.\nmake gawk\n\n# Install\ninstall -D gawk $out/bin/gawk\nln -s gawk $out/bin/awk\n"),("builder","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("name","gawk-mes-3.0.6"),("out","/nix/store/5299jjmmxmwlld98w2z8mn1wa1hzcyhx-gawk-mes-3.0.6"),("passAsFile","buildCommand"),("pname","gawk-mes"),("system","i686-linux"),("version","3.0.6")])