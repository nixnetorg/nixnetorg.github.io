Derive([("out","/nix/store/am6s1vnjh41kkdd7d1jl9flrx988pka0-jail","","")],[("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/i2iy5vhwb7g1pv5svyyzhpcpagwvwwdv-stdenv-linux.drv",["out"]),("/nix/store/nli0vg7g3bnbxl1ybjas59bwswbdyg51-util-linux-minimal-2.42.drv",["bin"]),("/nix/store/qhsys02xpi9c4vmpqckazxyc8ykm4kvz-jail_init.drv",["out"]),("/nix/store/rrwx4izf1zb8k7394wkhk82xcy17g33q-coreutils-9.11.drv",["out"]),("/nix/store/vj2j7dn6fhmsbcbvk1920z9lk7sbmchh-busybox-mini.drv",["out"])],["/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("NIX_MAIN_PROGRAM","jail"),("__structuredAttrs",""),("allowSubstitutes","1"),("buildCommand","target=$out$destination\nmkdir -p \"$(dirname \"$target\")\"\n\nif [ -e \"$textPath\" ]; then\n  mv \"$textPath\" \"$target\"\nelse\n  printf \"%s\" \"$text\" > \"$target\"\nfi\n\nif [ -n \"$executable\" ]; then\n  chmod +x \"$target\"\nfi\n\neval \"$checkPhase\"\n"),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("checkPhase","runHook preCheck\n/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash -n -O extglob \"$target\"\n\nrunHook postCheck\n"),("cmakeFlags",""),("configureFlags",""),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("destination","/bin/jail"),("doCheck",""),("doInstallCheck",""),("executable","1"),("mesonFlags",""),("name","jail"),("nativeBuildInputs",""),("out","/nix/store/am6s1vnjh41kkdd7d1jl9flrx988pka0-jail"),("outputs","out"),("passAsFile","text"),("patches",""),("preferLocalBuild",""),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("stdenv","/nix/store/5wly0ig1rwgv67m1dr8gz1655drp3cmn-stdenv-linux"),("strictDeps",""),("system","i686-linux"),("text","#!/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash\nset -o errexit\nset -o nounset\nset -o pipefail\n\nexport PATH=\"/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin:/nix/store/l2z0c4ivxc914j8h8g537zdcyfrbga2h-coreutils-9.11/bin:/nix/store/gnhnf55iv89m2g9cq5xbgxriwgqarbn0-util-linux-minimal-2.42-bin/bin:/nix/store/6c0fjwgaxpnnlk5yna14kpan6f0442g3-busybox-mini/bin:/nix/store/drgmplr6wbi8f2j64i794chp6ak6yqkp-jail_init/bin:$PATH\"\n\n#!/usr/bin/env bash\n# Lightweight sandbox using Linux user/mount/net/pid namespaces and pivot_root.\n# Named jails (jail add) pin namespaces under /run/jail/<name> and register the\n# network namespace at /var/run/netns/<name>, making them compatible with ip netns.\n# Commands: add <name> (create named jail), enter <name> <cmd> (re-enter), exec <cmd> (one-shot).\nset -euo pipefail\n\n_unshare_jail() {\n  export NAME=\"$1\"; shift\n  export WAYLAND=false\n  export CHDIR=\"/pwd\"\n  export JAIL_BINDS=\"\"\n  export JAIL_SETENV=\"\"\n  while [[ \"${1:-}\" == --* ]]; do\n    case \"$1\" in\n      --wayland)  WAYLAND=true; shift ;;\n      --bind)     JAIL_BINDS+=\"rw:${2}:${3}\"$'\\n'; shift 3 ;;\n      --ro-bind)  JAIL_BINDS+=\"ro:${2}:${3}\"$'\\n'; shift 3 ;;\n      --setenv)   JAIL_SETENV+=\"${2}\"$'\\n'; shift 2 ;;\n      --chdir)    CHDIR=\"$2\"; shift 2 ;;\n      *) echo \"jail: unknown flag: $1\" >&2; exit 1 ;;\n    esac\n  done\n\n  local user_args=(\"--user\" \"--map-root-user\")\n  if [ \"$(id -u)\" -eq 0 ]; then\n    user_args=()\n  fi\n  local net_arg=\"--net\"\n  local uts_arg=\"--uts\"\n  local ipc_arg=\"--ipc\"\n  local cgroup_arg=\"--cgroup\"\n  local time_arg=\"--time\"\n  local mnt_arg=\"--mount\"\n  local pid_arg=\"--pid\"\n\n  if [ -n \"$NAME\" ]; then\n    mkdir -p \"/run/jail/$NAME\"\n    mkdir -p \"/var/run/netns\"\n    touch \"/run/jail/$NAME/user\"\n    touch \"/var/run/netns/$NAME\"\n    if [ \"$(id -u)\" -ne 0 ]; then\n      user_args=(\"--user=/run/jail/$NAME/user\" \"--map-root-user\")\n    fi\n    net_arg=\"--net=/var/run/netns/$NAME\"\n  fi\n\n  export HAS_USERNS=${#user_args[@]}\n  exec unshare \\\n    --keep-caps \\\n    --forward-signals \\\n    \"${user_args[@]}\" \\\n    \"$mnt_arg\" \\\n    \"$net_arg\" \\\n    \"$pid_arg\" \\\n    --fork \\\n    \"$uts_arg\" \\\n    \"$ipc_arg\" \\\n    \"$cgroup_arg\" \\\n    \"$time_arg\" \\\n    -- bash \"$(dirname \"$0\")/jail_setup\" \"$@\"\n}\n\n_jail_enter() {\n  local _name=\"$1\"; shift\n  # pid file indicates jail is ready\n  if [ ! -f \"/run/jail/$_name/pid\" ]; then\n    echo \"jail enter: '$_name' does not exist\" >&2\n    exit 1\n  fi\n  local _chdir\n  _chdir=\"$(sed -n 's/^PWD=//p' \"/run/jail/$_name/env\")\"\n  local -a _env\n  mapfile -t _env < \"/run/jail/$_name/env\"\n  local _init_pid\n  _init_pid=\"$(< \"/run/jail/$_name/pid\")\"\n  local _user_arg=(\"--user=/run/jail/$_name/user\")\n  if [ \"$(id -u)\" -eq 0 ]; then _user_arg=(); fi\n  # setpriv --pdeathsig TERM delivers SIGTERM to the entered command if its\n  # nsenter parent is killed, so signalling a single `jail enter` tears down just\n  # that command (running its cleanup trap) instead of orphaning it in the jail.\n  exec nsenter \\\n    --preserve-credentials \\\n    \"${_user_arg[@]}\" \\\n    --mount=\"/proc/$_init_pid/ns/mnt\" \\\n    --net=\"/var/run/netns/$_name\" \\\n    --pid=\"/proc/$_init_pid/ns/pid\" \\\n    --uts=\"/proc/$_init_pid/ns/uts\" \\\n    --ipc=\"/proc/$_init_pid/ns/ipc\" \\\n    -- setpriv --pdeathsig TERM \\\n    -- env \\\n      --ignore-environment \\\n      --chdir \"$_chdir\" \\\n      \"${_env[@]}\" \\\n      \"$@\"\n}\n\n_jail_exec() {\n  _unshare_jail \"\" \"$@\"\n}\n\n_jail_add() {\n  local _flags=()\n  while [[ \"${1:-}\" == --* ]]; do\n    case \"$1\" in\n      --bind|--ro-bind) _flags+=(\"$1\" \"$2\" \"$3\"); shift 3 ;;\n      --setenv|--chdir) _flags+=(\"$1\" \"$2\"); shift 2 ;;\n      --wayland)        _flags+=(\"$1\"); shift ;;\n      *) echo \"jail add: unknown flag: $1\" >&2; exit 1 ;;\n    esac\n  done\n  local _name=\"$1\"\n  mkdir -p \"/run/jail/$_name\"\n  # jail_setup writes outer init PID of jail to fifo when ready\n  local _fifo=\"/run/jail/$_name/.pid_fifo\"\n  mkfifo \"$_fifo\"\n  _unshare_jail \"$_name\" \"${_flags[@]}\" \"$(command -v init)\" &\n  disown\n  local _init_pid\n  read -r _init_pid < \"$_fifo\"\n  rm -f \"$_fifo\"\n  printf '%s\\n' \"$_init_pid\" > \"/run/jail/$_name/pid\"\n}\n\ncmd=\"${1:-}\"\nshift || true\n\ncase \"$cmd\" in\n  add)\n    _jail_add \"$@\"\n    ;;\n  exec)\n    _jail_exec \"$@\"\n    ;;\n  enter)\n    _jail_enter \"$@\"\n    ;;\n  *)\n    echo \"usage: jail add <name> | jail exec <cmd>... | jail enter <name> <cmd>...\" >&2\n    exit 1\n    ;;\nesac\n\n")])