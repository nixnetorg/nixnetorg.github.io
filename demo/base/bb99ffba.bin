ldCommand","# Unpack\ntar xzf /nix/store/lih1c5qn71i56blnj7bq7jhnm3k1z4q9-xz-5.8.3.tar.gz\ncd xz-5.8.3\n\n# Configure\nexport CC=\"tcc -B /nix/store/igkpl9ifkvqpxa20i378f300pvpqc5yj-tinycc-musl-unstable-2025-12-03-libs/lib\"\nexport AR=\"tcc -ar\"\nexport LD=tcc\n# With a lower max_cmd_len (which is mistakenly detected by the\n# configure script), libtool invokes ar in append mode. This is not\n# supported by tinycc.\nexport lt_cv_sys_max_cmd_len=32768\nbash ./configure \\\n  --prefix=$out \\\n  --build=i686-unknown-linux-gnu \\\n  --host=i686-unknown-linux-gnu \\\n  --disable-shared \\\n  --disable-assembler \\\n  --disable-dependency-tracking\n\n# Build\nmake -j $NIX_BUILD_CORES\n\n# Install\nmake -j $NIX_BUILD_CORES install\n"),("builder","/nix/store/bpf636xrnh0icn1bvyi5zkxhspmmgfyd-bash-2.05b/bin/bash"),("name","xz-5.8.3"),("out","/nix/store/jf5kd2s17bp88w9axwz2525206sw4shq-xz-5.8.3"),("passAsFile","buildCommand"),("pname","xz"),("system","i686-linux"),("version","5.8.3")])