Derive([("bin","/nix/store/al3am8hgahlsb6a4l91py2yhqavigcjh-openssl-3.6.2-bin","",""),("debug","/nix/store/7zbfh8by0k30l0fxz991vgc87qzgqk6a-openssl-3.6.2-debug","",""),("dev","/nix/store/wwyfm4j697k9icdfly975b5bcnjhxlkr-openssl-3.6.2-dev","",""),("doc","/nix/store/fd3h5xirdad9l2jz1bgph1dim7m4wxlj-openssl-3.6.2-doc","",""),("man","/nix/store/vpcrdygs4gg3m7fagx169yahqdgp884c-openssl-3.6.2-man","",""),("out","/nix/store/407wxvr0l1ffpl7rj79519903k0l5fj7-openssl-3.6.2","","")],[("/nix/store/00yfr3x8lkhmnj8cvrkqivxjkr8idgbk-stdenv-linux.drv",["out"]),("/nix/store/8837v4mfxvql8wj0qcp554cj81kjlliw-coreutils-9.11.drv",["out"]),("/nix/store/a9xrwk0gp9ni3pljp5nz5v0ch73gj5r6-openssl-3.6.2.tar.gz.drv",["out"]),("/nix/store/alpd1w45rsync1ga1y5sd39sp1khqk66-perl-5.42.0.drv",["out"]),("/nix/store/aysr2sxpdyr97wy8825kbh306hzm3zsa-bash-5.3p9.drv",["out"]),("/nix/store/cly1nrp632znn7p52if5d83ayik750b8-make-binary-wrapper-hook.drv",["out"])],["/nix/store/cklrwbwi889pp2fdsswdjvn12sdy5i5j-openssl-disable-kernel-detection.patch","/nix/store/i58agvhx8bmdjlspgkk4m3ylh5348iim-use-etc-ssl-certs.patch","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/r989dk196nl9frhnfsa1lb7knhbyjxw6-separate-debug-info.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh","/nix/store/sq4h6bqjx12v9whvm65pjss25hg1538q-nix-ssl-cert-file.patch"],"i686-linux","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash",["-e","/nix/store/l622p70vy8k5sh7y5wizi5f2mic6ynpg-source-stdenv.sh","/nix/store/shkw4qm9qcw5sc5n1k5jznc83ny02r39-default-builder.sh"],[("NIX_MAIN_PROGRAM","openssl"),("__structuredAttrs",""),("bin","/nix/store/al3am8hgahlsb6a4l91py2yhqavigcjh-openssl-3.6.2-bin"),("buildInputs",""),("builder","/nix/store/ksdxvc92sa7h6yppixfl4xyj6632vf0x-bash-5.3p9/bin/bash"),("cmakeFlags",""),("configureFlags","shared --libdir=lib --openssldir=etc/ssl enable-ktls"),("configurePlatforms",""),("configureScript","./config"),("debug","/nix/store/7zbfh8by0k30l0fxz991vgc87qzgqk6a-openssl-3.6.2-debug"),("depsBuildBuild",""),("depsBuildBuildPropagated",""),("depsBuildTarget",""),("depsBuildTargetPropagated",""),("depsHostHost",""),("depsHostHostPropagated",""),("depsTargetTarget",""),("depsTargetTargetPropagated",""),("dev","/nix/store/wwyfm4j697k9icdfly975b5bcnjhxlkr-openssl-3.6.2-dev"),("doCheck","1"),("doInstallCheck",""),("doc","/nix/store/fd3h5xirdad9l2jz1bgph1dim7m4wxlj-openssl-3.6.2-doc"),("dontAddStaticConfigureFlags","1"),("enableParallelBuilding","1"),("enableParallelChecking","1"),("enableParallelInstalling","1"),("makeFlags","MANDIR=$(man)/share/man MANSUFFIX=ssl"),("man","/nix/store/vpcrdygs4gg3m7fagx169yahqdgp884c-openssl-3.6.2-man"),("mesonFlags",""),("name","openssl-3.6.2"),("nativeBuildInputs","/nix/store/wzh85wi312m2rq2s7psgkvdrsmzagw86-make-binary-wrapper-hook /nix/store/vabrsyx4s3sn35x98yz66dakxxajd0xd-perl-5.42.0 /nix/store/r989dk196nl9frhnfsa1lb7knhbyjxw6-separate-debug-info.sh"),("out","/nix/store/407wxvr0l1ffpl7rj79519903k0l5fj7-openssl-3.6.2"),("outputs","bin dev out man doc debug"),("patches","/nix/store/sq4h6bqjx12v9whvm65pjss25hg1538q-nix-ssl-cert-file.patch /nix/store/cklrwbwi889pp2fdsswdjvn12sdy5i5j-openssl-disable-kernel-detection.patch /nix/store/i58agvhx8bmdjlspgkk4m3ylh5348iim-use-etc-ssl-certs.patch"),("pname","openssl"),("postFixup","# Check to make sure the main output and the static runtime dependencies\n# don't depend on perl\nif grep -r '/nix/store/vabrsyx4s3sn35x98yz66dakxxajd0xd-perl-5.42.0' $out $etc; then\n  echo \"Found an erroneous dependency on perl ^^^\" >&2\n  exit 1\nfi\n# cleanup cmake helpers for now (for OpenSSL >= 3.3), only rely on pkg-config.\n# pkg-config gets its paths fixed correctly\nrm -rf $dev/lib/cmake\n"),("postInstall","# If we're building dynamic libraries, then don't install static\n# libraries.\nif [ -n \"$(echo $out/lib/*.so $out/lib/*.dylib $out/lib/*.dll)\" ]; then\n    rm \"$out/lib/\"*.a\nfi\n\n# 'etc' is a separate output on static builds only.\netc=$out\nmkdir -p $bin\nmv $out/bin $bin/bin\n\n# c_rehash is a legacy perl script with the same functionality\n# as `openssl rehash`\n# this wrapper script is created to maintain backwards compatibility without\n# depending on perl\nmakeWrapper $bin/bin/openssl $bin/bin/c_rehash \\\n  --add-flags \"rehash\"\n\nmkdir $dev\nmv $out/include $dev/\n\n# remove dependency on Perl at runtime\nrm -r $etc/etc/ssl/misc\n\nrmdir $etc/etc/ssl/{certs,private}\n"),("postPatch","patchShebangs Configure\nsubstituteInPlace config --replace '/usr/bin/env' '/nix/store/hhiaj9mc4zps3yw7kphklmcw4xsc0864-coreutils-9.11/bin/env'\n"),("preCheck","patchShebangs util\n"),("propagatedBuildInputs",""),("propagatedNativeBuildInputs",""),("separateDebugInfo","1"),("setOutputFlags",""),("src","/nix/store/c2d7chn37a4q79xby5k12kcdqa905vnl-openssl-3.6.2.tar.gz"),("stdenv","/nix/store/0yq2fyi4p1jzmlh17xmy9f2nh4nxi0md-stdenv-linux"),("strictDeps",""),("system","i686-linux"),("version","3.6.2")])